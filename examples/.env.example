# DENG Tool: Rejoin — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit your actual .env file to version control.

# ── Supabase (remote license backend) ─────────────────────────────────────────
# Required only when license.mode=remote is configured.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Discord License Panel Bot ──────────────────────────────────────────────────
# The bot token for the Discord bot that hosts the license panel.
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ── Admin Discord user IDs (comma-separated) ──────────────────────────────────
# These users can run /license_panel admin commands and manage keys.
LICENSE_OWNER_DISCORD_IDS=123456789012345678,987654321098765432

# ── Optional: encrypted full-key export (Key Stats / Download) ─────────────────
# Newly generated keys can store ciphertext when this is set (needs migration 002 + cryptography).
# Keys without ciphertext can be backfilled via Recover Full Key or redeem-again (same user).
# LICENSE_KEY_EXPORT_SECRET=

# ── Optional: Discord embed logo (HTTPS URL, or rely on LICENSE_API_PUBLIC_URL default path) ──
# DENG_BRANDING_LOGO_URL=https://your.cdn.example/denghub_logo.png

# Public base URL of the license API (reverse proxy). Thumbnail defaults to {URL}/assets/denghub_logo.png
# LICENSE_API_PUBLIC_URL=https://rejoin.deng.my.id

# ── Development / testing bypass ──────────────────────────────────────────────
# Set to any non-empty value to skip license key verification entirely.
# NEVER set this in production.
# DENG_DEV=1

# ── App home override (optional) ──────────────────────────────────────────────
# Override the default ~/.deng-tool/rejoin data directory.
# DENG_REJOIN_HOME=/custom/data/path
