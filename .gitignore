__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Secrets — never commit
.env
*.env
.env.*
*.env.local

config.json
data/
!data/rejoin_versions.json
# The bare `data/` ignore above also (incorrectly) matched the Kotlin
# `data` PACKAGE used by the Android app — Models.kt, MonitorApi.kt,
# SessionStore.kt, etc. Re-include them so the APK's networking layer
# is actually tracked in git instead of living only on the build box.
!android/app/src/main/kotlin/my/id/deng/monitor/data/
!android/app/src/main/kotlin/my/id/deng/monitor/data/**
!android/app/src/test/kotlin/my/id/deng/monitor/data/
!android/app/src/test/kotlin/my/id/deng/monitor/data/**
logs/
run/
backups/
# Root-only launcher working dir (do not ignore releases/launcher/)
/launcher/

install.sh.tmp

# Private FishTracker dev source — never commit raw tracker.lua to public repo (BLOCKER10ZO)
tracker.lua
*.raw.lua
private/
dev-source/
