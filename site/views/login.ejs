<div class="auth-center">
  <section class="auth-card">
    <div class="auth-brand">
      <div class="auth-brand-icon login-logo" aria-hidden="true">
        <img src="/public/img/deng-logo.png?v=<%= assetVersion %>" alt="">
      </div>
      <h1 class="auth-brand-name">DENG <span class="brand-accent">Tool</span></h1>
      <p class="auth-tagline">Secure portal for DENG Tool: Rejoin</p>
    </div>

    <% if (flash && flash.error) { %>
      <div class="alert alert-error" role="alert"><%= flash.error %></div>
    <% } %>
    <% if (flash && flash.success) { %>
      <div class="alert alert-success" role="alert"><%= flash.success %></div>
    <% } %>

    <a href="/auth/discord" class="btn btn-discord">Continue With Discord</a>
  </section>
</div>
