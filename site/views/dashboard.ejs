<% locals.activePage = 'dashboard' %>

<div class="page-header">
  <div>
    <p class="eyebrow">DENG Tool Portal</p>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Welcome back, <strong><%= user.username %></strong>.</p>
  </div>
  <a href="/license" class="btn btn-primary">Go to My License</a>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-body">
      <p class="stat-label">Unredeemed Keys</p>
      <p class="stat-value"><%= stats.unredeemed %></p>
    </div>
  </div>
</div>

<section class="section-card">
  <p class="section-desc">Generate a license key from <a href="/license">My License</a>, then redeem it inside DENG Tool: Rejoin to activate the tool.</p>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Recent Key Activity</h2>
      <p class="section-desc">Dashboard keys are masked. Open My License after unlock to view a fresh key.</p>
    </div>
    <a href="/license" class="btn btn-sm btn-outline">Go to My License</a>
  </div>

  <% if (history && history.length > 0) { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Key</th>
            <th>Provider</th>
            <th>Status</th>
            <th>Generated</th>
          </tr>
        </thead>
        <tbody>
          <% history.forEach(row => { %>
            <tr>
              <td class="key-cell"><code><%= row.key_prefix ? row.key_prefix + '-****-****' : 'Pending' %></code></td>
              <td><span class="badge badge-provider"><%= row.provider || 'Pending' %></span></td>
              <td><span class="badge badge-gray"><%= row.status === 'key_generated' ? 'Generated' : row.status %></span></td>
              <td class="muted-cell"><%= new Date(row.created_at).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">
      <p class="empty-title">No keys yet</p>
      <p class="empty-text">Generate your first key from My License.</p>
      <a href="/license" class="btn btn-primary btn-sm">Generate Key</a>
    </div>
  <% } %>
</section>
