<% locals.activePage = 'dashboard' %>

<div class="page-header">
  <div>
    <p class="eyebrow">DENG Tool Portal</p>
    <h1 class="page-title">Dashboard Overview</h1>
    <p class="page-subtitle">Welcome back, <strong><%= user.username %></strong>. Manage your DENG Tool: Rejoin key flow from one clean panel.</p>
  </div>
  <a href="/license" class="btn btn-primary">Generate Key</a>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-body">
      <p class="stat-label">Total Licenses</p>
      <p class="stat-value"><%= stats.total %></p>
      <p class="stat-note">Lifetime generated / owned keys</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-body">
      <p class="stat-label">Unused Keys</p>
      <p class="stat-value"><%= stats.unredeemed %></p>
      <p class="stat-note">Ready to redeem in Rejoin</p>
    </div>
  </div>
</div>

<section class="section-card">
  <div class="section-header compact">
    <div>
      <h2 class="section-title">News & Updates</h2>
      <p class="section-desc">DENG Tool: Rejoin Portal is now live.</p>
    </div>
  </div>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Your Activity</h2>
      <p class="section-desc">Account access and generated keys are tied to your Discord login.</p>
    </div>
    <a href="/license" class="btn btn-sm btn-outline">My License</a>
  </div>

  <% if (history && history.length > 0) { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Key</th>
            <th>Provider</th>
            <th>Status</th>
            <th>Generated</th>
          </tr>
        </thead>
        <tbody>
          <% history.forEach(row => { %>
            <tr>
              <td class="key-cell"><code><%= fullKeyRow(row) %></code></td>
              <td><span class="badge badge-provider"><%= providerLabel(row.provider) %></span></td>
              <td><span class="badge <%= friendlyStatus(row) === 'Generated' ? 'badge-green' : (friendlyStatus(row) === 'Expired' ? 'badge-red' : 'badge-gray') %>"><%= friendlyStatus(row) %></span></td>
              <td class="muted-cell"><%= formatWibTimestamp(row.created_at) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">
      <p class="empty-title">Joined Program</p>
      <p class="empty-text">Security Status: Account Protected</p>
      <a href="/license" class="btn btn-primary btn-sm">Generate Key</a>
    </div>
  <% } %>
</section>
