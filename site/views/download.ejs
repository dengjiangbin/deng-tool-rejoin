<% locals.activePage = 'download' %>

<div class="page-header">
  <div>
    <p class="eyebrow">DENG All In One</p>
    <h1 class="page-title">
      <span class="gradient-brand-text">DENG All In One Monitor</span>
    </h1>
    <p class="page-subtitle">
      Monitor your Rejoin packages from Android or iOS. View RAM, package state,
      snapshots, and Fish It stats — same account, same backend.
    </p>
  </div>
  <div class="download-platform-row">
    <div class="download-cta-col">
      <p class="download-platform-label">Android</p>
      <% if (manifest && manifest.file_name) { %>
        <a href="/downloads/<%= encodeURIComponent(manifest.file_name) %>?v=<%= manifest.version_name %>" class="btn btn-primary" data-apk-download rel="nofollow">
          Download DENG All In One APK
        </a>
        <p class="apk-download-count" data-apk-download-count hidden aria-live="polite">
          <span class="apk-download-count-skel" data-apk-count-skel></span>
          <span class="apk-download-count-text" data-apk-count-text hidden></span>
        </p>
      <% } else { %>
        <span class="btn btn-outline" aria-disabled="true">APK not published yet</span>
      <% } %>
    </div>
    <div class="download-cta-col">
      <p class="download-platform-label">iOS</p>
      <% if (iosMode === 'testflight' && testflightUrl) { %>
        <a href="<%= testflightUrl %>" class="btn btn-primary" data-ios-download target="_blank" rel="noopener noreferrer">
          Join iOS TestFlight
        </a>
        <p class="apk-download-count" data-ios-download-count hidden aria-live="polite">
          <span class="apk-download-count-skel" data-ios-count-skel></span>
          <span class="apk-download-count-text" data-ios-count-text hidden></span>
        </p>
      <% } else if (iosMode === 'ipa' && iosManifest && iosManifest.file_name) { %>
        <a href="/downloads/deng-tool-monitor-ios-latest.ipa" class="btn btn-primary" data-ios-download rel="nofollow">
          Download iOS Test Build
        </a>
        <p class="apk-download-count" data-ios-download-count hidden aria-live="polite">
          <span class="apk-download-count-skel" data-ios-count-skel></span>
          <span class="apk-download-count-text" data-ios-count-text hidden></span>
        </p>
        <p class="stat-note">Private/ad-hoc build — requires registered device UDID.</p>
      <% } else { %>
        <span class="btn btn-outline" aria-disabled="true">iOS coming soon</span>
        <p class="stat-note">TestFlight or App Store distribution is being set up.</p>
      <% } %>
    </div>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-body">
      <p class="stat-label">App Version</p>
      <p class="stat-value"><%= manifest ? ('v' + manifest.version_name) : '—' %></p>
      <p class="stat-note">Android APK release version only — not Rejoin package version.</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-body">
      <p class="stat-label">Purpose</p>
      <p class="stat-value" style="font-size: 1.05rem;">Monitoring companion app</p>
      <p class="stat-note">Read-only. Rejoin packages still run in Termux.</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-body">
      <p class="stat-label">Backend</p>
      <p class="stat-value" style="font-size: 1.05rem;">aio.deng.my.id</p>
      <p class="stat-note">Internal API / monitor bridge (not the public website host).</p>
    </div>
  </div>
</div>

<section class="section-card" id="pair-android-app">
  <div class="section-header">
    <div>
      <h2 class="section-title">Pair Android App</h2>
      <p class="section-desc">
        After installing DENG All In One, open the app and sign in with Discord.
      </p>
    </div>
  </div>

  <% if (user) { %>
    <div class="pair-panel" data-pair-panel>
      <div class="pair-actions" data-pair-actions>
        <button type="button" class="btn btn-primary" data-pair-generate>
          Generate Pair Code
        </button>
        <p class="section-desc pair-hint" data-pair-hint>
          Click to generate a one-time 8-character code. It expires in 5 minutes.
        </p>
      </div>

      <div class="pair-result" data-pair-result hidden>
        <p class="pair-result-label">Pairing Code</p>
        <div class="pair-code-row">
          <input
            type="text"
            class="pair-code-field"
            data-pair-code
            readonly
            autocomplete="off"
            spellcheck="false"
            aria-label="Pairing code">
          <button type="button" class="btn btn-outline pair-copy-btn" data-pair-copy>
            Copy Code
          </button>
        </div>
        <p class="pair-meta">
          <span data-pair-expiry>Expires in 5 minutes.</span><br>
          Open <strong>DENG All In One APK</strong> → <em>Pair Device</em> →
          paste this code.
        </p>
        <p class="pair-error" data-pair-error hidden role="alert"></p>
      </div>
    </div>
  <% } else { %>
    <div class="pair-panel pair-panel-loggedout" data-pair-panel-loggedout>
      <p class="pair-loggedout-msg">
        Log in with Discord to generate a pairing code.
      </p>
      <a href="/auth/discord" class="btn btn-discord">Log in with Discord</a>
    </div>
  <% } %>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Install Instructions</h2>
      <p class="section-desc">Sideload the APK on your Android device or cloud phone.</p>
    </div>
  </div>

  <ol class="install-steps">
    <li>Open this page on your Android device or cloud phone.</li>
    <li>Tap <strong>Download APK</strong> above.</li>
    <li>If asked, allow installs from this browser in Android Settings.</li>
    <li>Open the downloaded <code>.apk</code> and tap <strong>Install</strong>.</li>
    <li>Open <strong>DENG All In One APK</strong>, then enter the pairing
      code generated above in <strong>Pair Android App</strong>.</li>
    <li>In Termux on your cloud phone, run <code>deng-rejoin</code>. The Rejoin agent
      will auto-start the monitor bridge after license verification.</li>
  </ol>

  <div class="alert alert-warning" role="note" style="margin-top: 1rem;">
    Only download from <%= publicUrl %>/download. Do not install APK files
    from unofficial sources — they may be tampered with.
  </div>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Versioning</h2>
      <p class="section-desc">How APK releases relate to Rejoin packages.</p>
    </div>
  </div>
  <ul class="install-steps">
    <li>This APK has its own Android release version (currently
      <strong>v<%= manifest ? manifest.version_name : '1.0.0' %></strong>).</li>
    <li>Rejoin package versions (stable / main-dev / test) are selected
      separately on your dashboard or via the Discord <em>Select Version</em>
      command — they are not tied to APK versions.</li>
    <li>The APK is a monitoring companion only; it does not change which
      Rejoin package version is installed in Termux.</li>
  </ul>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Integrity / SHA-256</h2>
      <p class="section-desc">Verify the APK matches the official build before installing.</p>
    </div>
  </div>
  <% if (manifest && manifest.sha256) { %>
    <pre class="code-block"><code><%= manifest.sha256 %>  <%= manifest.file_name %></code></pre>
    <p class="section-desc">
      On Termux: <code>sha256sum <%= manifest.file_name %></code>.<br>
      On desktop PowerShell: <code>Get-FileHash <%= manifest.file_name %> -Algorithm SHA256</code>.
    </p>
  <% } else { %>
    <p class="section-desc">Checksum will appear here once the first APK is published.</p>
  <% } %>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Changelog</h2>
      <p class="section-desc">What's new in app version
        <strong>v<%= manifest ? manifest.version_name : '—' %></strong>.</p>
    </div>
  </div>
  <% if (manifest && manifest.changelog && manifest.changelog.length) { %>
    <ul class="install-steps">
      <% manifest.changelog.forEach(function(line) { %>
        <li><%= line %></li>
      <% }) %>
    </ul>
  <% } else { %>
    <p class="section-desc">No changelog available yet.</p>
  <% } %>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">What This App Shows</h2>
      <p class="section-desc">Public, monitoring-only. No license keys or private URLs are sent to the app.</p>
    </div>
  </div>
  <ul class="install-steps">
    <li>RAM usage per package, with formatted MB/GB display.</li>
    <li>Runtime per package (HH:MM:SS), restart count, last heartbeat.</li>
    <li>Live state: Online, Dead, Relaunching, No Heartbeat, Launching, Unknown.</li>
    <li>Latest cloud phone snapshot with configurable interval (Off / 15s / 30s / 60s / 5m).</li>
    <li>Summary card: total / online / dead / total RAM / average RAM.</li>
    <li>Device status: connected, last update, tool version, channel.</li>
  </ul>
</section>

<style>
  .install-steps {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.7;
  }
  .install-steps li {
    margin-bottom: 0.35rem;
  }
  .code-block {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    overflow-x: auto;
    font-size: 0.85rem;
    color: var(--text);
    word-break: break-all;
    white-space: pre-wrap;
  }

  /* ── Pair Android App ─────────────────────────────────────────── */
  .pair-panel { display: flex; flex-direction: column; gap: 1rem; }
  .pair-actions { display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start; }
  .pair-hint { margin: 0; }
  .pair-result-label {
    margin: 0 0 0.5rem;
    color: var(--muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .pair-code-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: stretch;
  }
  .pair-code-field {
    flex: 1 1 220px;
    min-width: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-align: center;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--code-bg);
    color: var(--text);
    -webkit-user-select: all;
    user-select: all;
  }
  .pair-code-field:focus { outline: 2px solid var(--cyan, #00cfff); outline-offset: 2px; }
  .pair-copy-btn { white-space: nowrap; }
  .pair-copy-btn.is-copied { background: var(--success, #1f8a4d); color: #fff; border-color: transparent; }
  .pair-meta {
    margin: 0.85rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .pair-error {
    margin: 0.5rem 0 0;
    color: var(--danger, #ff5277);
    font-size: 0.9rem;
  }
  .pair-panel-loggedout {
    align-items: flex-start;
  }
  .pair-loggedout-msg {
    margin: 0 0 0.85rem;
    color: var(--muted);
  }
</style>

<script>
(function initPairAndroidApp() {
  var panel = document.querySelector('[data-pair-panel]');
  if (!panel) return;
  var btnGen   = panel.querySelector('[data-pair-generate]');
  var hint     = panel.querySelector('[data-pair-hint]');
  var result   = panel.querySelector('[data-pair-result]');
  var codeEl   = panel.querySelector('[data-pair-code]');
  var copyBtn  = panel.querySelector('[data-pair-copy]');
  var expiryEl = panel.querySelector('[data-pair-expiry]');
  var errEl    = panel.querySelector('[data-pair-error]');
  var countdownTimer = null;

  function setError(msg) {
    if (!errEl) return;
    if (msg) { errEl.textContent = msg; errEl.hidden = false; }
    else     { errEl.textContent = '';  errEl.hidden = true;  }
  }

  function formatRemaining(ms) {
    if (!Number.isFinite(ms) || ms <= 0) return 'Expired. Generate a new code.';
    var totalSec = Math.max(1, Math.round(ms / 1000));
    var m = Math.floor(totalSec / 60);
    var s = totalSec % 60;
    var pad = function (n) { return n < 10 ? '0' + n : String(n); };
    return 'Expires in ' + m + ':' + pad(s) + '.';
  }

  function startCountdown(expiresAtIso) {
    if (countdownTimer) { clearInterval(countdownTimer); countdownTimer = null; }
    var expiresAt = Date.parse(expiresAtIso);
    if (!Number.isFinite(expiresAt)) {
      expiryEl.textContent = 'Expires in 5 minutes.';
      return;
    }
    var tick = function () {
      var remaining = expiresAt - Date.now();
      expiryEl.textContent = formatRemaining(remaining);
      if (remaining <= 0) {
        clearInterval(countdownTimer);
        countdownTimer = null;
      }
    };
    tick();
    countdownTimer = setInterval(tick, 1000);
  }

  function fallbackCopy(text) {
    return new Promise(function (resolve, reject) {
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.position = 'fixed';
      ta.style.top = '-1000px';
      ta.style.left = '-1000px';
      document.body.appendChild(ta);
      try {
        ta.focus(); ta.select();
        var ok = document.execCommand && document.execCommand('copy');
        document.body.removeChild(ta);
        if (ok) resolve(); else reject(new Error('copy_failed'));
      } catch (e) {
        try { document.body.removeChild(ta); } catch (_) {}
        reject(e);
      }
    });
  }

  function copyCode() {
    var text = codeEl ? codeEl.value : '';
    if (!text) return;
    var done = function () {
      copyBtn.classList.add('is-copied');
      copyBtn.textContent = 'Copied';
      setTimeout(function () {
        copyBtn.classList.remove('is-copied');
        copyBtn.textContent = 'Copy Code';
      }, 1800);
    };
    var fail = function () {
      // Visible code stays selected so user can long-press / Ctrl+C manually.
      if (codeEl && codeEl.setSelectionRange) {
        codeEl.focus();
        try { codeEl.setSelectionRange(0, text.length); } catch (_) {}
      }
      setError('Auto-copy failed. The code is selected — press Ctrl+C / long-press to copy.');
    };
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(done).catch(function () {
        fallbackCopy(text).then(done).catch(fail);
      });
    } else {
      fallbackCopy(text).then(done).catch(fail);
    }
  }

  function generate() {
    if (!btnGen) return;
    btnGen.disabled = true;
    var originalText = btnGen.textContent;
    btnGen.textContent = 'Generating…';
    setError('');
    fetch('/api/monitor/pairing/create', {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: '{}'
    })
      .then(function (res) {
        if (res.status === 401 || res.status === 403) {
          throw new Error('You need to log in with Discord first.');
        }
        if (res.status === 429) {
          throw new Error('Too many requests. Please wait a moment and try again.');
        }
        if (!res.ok) {
          throw new Error('Pair code service is unavailable. Try again in a minute.');
        }
        return res.json();
      })
      .then(function (data) {
        var code = data && typeof data.code === 'string' ? data.code : '';
        if (!code) throw new Error('Server did not return a pairing code.');
        codeEl.value = code;
        result.hidden = false;
        if (hint) hint.textContent = 'Code generated. Enter it in DENG All In One APK within 5 minutes.';
        btnGen.textContent = 'Generate New Code';
        startCountdown(data.expires_at);
      })
      .catch(function (err) {
        setError(err && err.message ? err.message : 'Unable to generate pair code.');
        btnGen.textContent = originalText;
      })
      .then(function () { btnGen.disabled = false; });
  }

  if (btnGen) btnGen.addEventListener('click', generate);
  if (copyBtn) copyBtn.addEventListener('click', copyCode);
  if (codeEl) codeEl.addEventListener('focus', function () {
    if (codeEl.setSelectionRange && codeEl.value) {
      try { codeEl.setSelectionRange(0, codeEl.value.length); } catch (_) {}
    }
  });
}());
</script>
<script>
(function () {
  'use strict';
  var wrap = document.querySelector('[data-apk-download-count]');
  if (!wrap) return;
  var skel = wrap.querySelector('[data-apk-count-skel]');
  var textEl = wrap.querySelector('[data-apk-count-text]');
  var btn = document.querySelector('[data-apk-download]');
  wrap.hidden = false;
  if (skel) skel.classList.add('is-loading');

  function fmt(n) {
    var v = Number(n);
    if (!isFinite(v)) return '0';
    return Math.round(v).toLocaleString('en-US');
  }

  function showCount(n) {
    if (skel) skel.hidden = true;
    if (textEl) {
      textEl.hidden = false;
      if (window.DengCountUpStats) {
        textEl.classList.add('js-count-up');
        window.DengCountUpStats.set(textEl, { to: n, format: 'integer', suffix: ' downloads' });
      } else {
        textEl.textContent = fmt(n) + ' downloads';
      }
      wrap.classList.add('is-ready');
    }
  }

  function showUnavailable() {
    wrap.hidden = true;
  }

  fetch('/api/downloads/apk/stats', { headers: { Accept: 'application/json' } })
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data || !data.ok || !data.latest) { showUnavailable(); return; }
      showCount(data.latest.downloads);
    })
    .catch(showUnavailable);

  if (btn) {
    btn.addEventListener('click', function () {
      if (!textEl || textEl.hidden) return;
      var m = textEl.textContent.match(/^([\d,]+)/);
      if (!m) return;
      var n = parseInt(m[1].replace(/,/g, ''), 10);
      if (!isFinite(n)) return;
      showCount(n + 1);
      setTimeout(function () {
        fetch('/api/downloads/apk/stats', { headers: { Accept: 'application/json' } })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (data) {
            if (data && data.ok && data.latest) showCount(data.latest.downloads);
          })
          .catch(function () {});
      }, 4000);
    });
  }
}());
</script>
<script>
(function () {
  'use strict';
  var wrap = document.querySelector('[data-ios-download-count]');
  if (!wrap) return;
  var skel = wrap.querySelector('[data-ios-count-skel]');
  var textEl = wrap.querySelector('[data-ios-count-text]');
  var btn = document.querySelector('[data-ios-download]');
  wrap.hidden = false;
  if (skel) skel.classList.add('is-loading');

  function fmt(n) {
    var v = Number(n);
    if (!isFinite(v)) return '0';
    return Math.round(v).toLocaleString('en-US');
  }

  function showCount(n) {
    if (skel) skel.hidden = true;
    if (textEl) {
      textEl.hidden = false;
      if (window.DengCountUpStats) {
        textEl.classList.add('js-count-up');
        window.DengCountUpStats.set(textEl, { to: n, format: 'integer', suffix: ' downloads' });
      } else {
        textEl.textContent = fmt(n) + ' downloads';
      }
      wrap.classList.add('is-ready');
    }
  }

  fetch('/api/downloads/ios/stats', { headers: { Accept: 'application/json' } })
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data || !data.ok || !data.latest || !data.latest.downloads) {
        wrap.hidden = true;
        return;
      }
      showCount(data.latest.downloads);
    })
    .catch(function () { wrap.hidden = true; });

  if (btn) {
    btn.addEventListener('click', function () {
      if (!textEl || textEl.hidden) return;
      var m = textEl.textContent.match(/^([\d,]+)/);
      if (!m) return;
      showCount(parseInt(m[1].replace(/,/g, ''), 10) + 1);
    });
  }
}());
</script>
