  <main class="deng-home-main">
    <section class="deng-home-hero" aria-labelledby="home-hero-title">
      <div class="deng-home-container">
        <div class="deng-home-hero__pill" data-home-online-pill hidden>
          <span class="deng-home-hero__dot" aria-hidden="true"></span>
          <span data-home-online-text>Live network online</span>
        </div>
        <h1 id="home-hero-title" class="deng-home-hero__title deng-home-hero__title--interactive" aria-label="DENG Tool">
          <span class="deng-home-hero__wordmark" aria-hidden="true">
            <span class="deng-home-hero__bracket deng-home-hero__bracket--tl"></span>
            <span class="deng-home-hero__bracket deng-home-hero__bracket--tr"></span>
            <span class="deng-home-hero__bracket deng-home-hero__bracket--bl"></span>
            <span class="deng-home-hero__bracket deng-home-hero__bracket--br"></span>
            <span class="deng-home-hero__word deng-home-hero__word--accent">DENG</span>
            <span class="deng-home-hero__word">Tool</span>
          </span>
        </h1>
        <p class="deng-home-hero__subtitle">
          A complete automation &amp; telemetry suite for Roblox. Track stats, inventories,
          sessions, and tools from one dashboard.
        </p>
        <div class="deng-home-hero__actions">
          <a class="deng-home-btn deng-home-btn--primary" href="/login">
            <span>Get Started</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14"></path><path d="m13 6 6 6-6 6"></path></svg>
          </a>
          <a class="deng-home-btn deng-home-btn--secondary" href="https://discord.gg/v74u5ZtuXf" target="_blank" rel="noopener noreferrer">
