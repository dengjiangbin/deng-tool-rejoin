<link rel="stylesheet" href="/public/css/public-theme.css?v=<%= assetVersion %>">
<link rel="stylesheet" href="/public/css/home.css?v=<%= assetVersion %>">

<div class="deng-home" id="top">
  <header class="deng-home-nav-wrap deng-home-nav-wrap--fixed" aria-label="Site navigation">
    <div class="deng-home-nav">
      <div class="deng-home-nav__inner">
        <a class="deng-home-brand" href="/" aria-label="Go to home">
          <span class="deng-home-brand__mark" aria-hidden="true">
            <img src="/public/img/deng-logo.png?v=<%= assetVersion %>" alt="">
          </span>
          <span class="deng-home-brand__text">DENG All In One</span>
        </a>
        <nav class="deng-home-nav__links" aria-label="Primary">
          <a class="deng-home-nav__link is-active" href="#home" data-nav-section="home">Home</a>
          <a class="deng-home-nav__link" href="#statistic" data-nav-section="statistic">Statistic</a>
          <a class="deng-home-nav__link" href="#about" data-nav-section="about">About</a>
        </nav>
        <div class="deng-home-nav__actions">
          <a class="deng-home-nav__signin" href="/login">Sign In</a>
        </div>
      </div>
    </div>
  </header>

  <main class="deng-home-main">
    <section class="deng-home-hero deng-home-anchor" id="home" data-home-section="home" aria-labelledby="home-hero-title">
      <div class="deng-home-container">
        <div class="deng-home-hero__pill deng-home-hero__pill--offline" data-home-online-pill>
          <span class="deng-home-hero__dot" aria-hidden="true"></span>
          <span class="deng-home-hero__online-count" data-home-online-text>No One Online</span>
        </div>
        <h1 id="home-hero-title" class="deng-home-hero__title" aria-label="DENG All In One">
          <span class="hero-wordmark" data-hero-wordmark>
            <span class="hero-word is-active" data-hero-word="deng" tabindex="0">
              <span class="hero-corner hero-corner--tl" aria-hidden="true"></span>
              <span class="hero-corner hero-corner--tr" aria-hidden="true"></span>
              <span class="hero-corner hero-corner--bl" aria-hidden="true"></span>
              <span class="hero-corner hero-corner--br" aria-hidden="true"></span>
              <span class="hero-word__text">DENG</span>
            </span>
            <span class="hero-word" data-hero-word="aio" tabindex="0">
              <span class="hero-corner hero-corner--tl" aria-hidden="true"></span>
              <span class="hero-corner hero-corner--tr" aria-hidden="true"></span>
              <span class="hero-corner hero-corner--bl" aria-hidden="true"></span>
              <span class="hero-corner hero-corner--br" aria-hidden="true"></span>
              <span class="hero-word__text">All In One</span>
            </span>
          </span>
        </h1>
        <p class="deng-home-hero__subtitle">
          A complete automation &amp; telemetry suite for Roblox. Track stats, inventories,
          sessions, and tools from one dashboard.
        </p>
        <div class="deng-home-hero__actions">
          <a class="deng-home-btn deng-home-btn--primary" href="/login">
            <span>Get Started</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14"></path><path d="m13 6 6 6-6 6"></path></svg>
          </a>
          <a class="deng-home-btn deng-home-btn--secondary" href="https://discord.gg/v74u5ZtuXf" target="_blank" rel="noopener noreferrer">
            <svg class="deng-home-btn__discord" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.317 4.369A19.8 19.8 0 0 0 15.885 3a13.6 13.6 0 0 0-.617 1.27 18.3 18.3 0 0 0-5.535 0A13 13 0 0 0 9.11 3 19.7 19.7 0 0 0 4.677 4.37C1.86 8.57 1.096 12.66 1.478 16.693a19.9 19.9 0 0 0 6.073 3.078c.49-.668.927-1.377 1.304-2.122a13 13 0 0 1-2.053-.99c.172-.126.34-.257.503-.392a14.2 14.2 0 0 0 12.087 0c.165.14.333.27.503.392-.655.39-1.345.722-2.056.99.377.745.814 1.454 1.304 2.122a19.8 19.8 0 0 0 6.075-3.078c.448-4.67-.766-8.72-3.204-12.324M8.79 14.222c-1.183 0-2.157-1.085-2.157-2.42 0-1.334.955-2.42 2.157-2.42 1.21 0 2.176 1.095 2.157 2.42 0 1.335-.955 2.42-2.157 2.42m7.42 0c-1.183 0-2.157-1.085-2.157-2.42 0-1.334.955-2.42 2.157-2.42 1.21 0 2.176 1.095 2.157 2.42 0 1.335-.946 2.42-2.157 2.42"></path>
            </svg>
            <span>Join Discord</span>
          </a>
        </div>
      </div>
    </section>

    <section class="deng-home-section deng-home-section--stats deng-home-anchor" id="statistic" aria-labelledby="home-stats-title" data-home-section="statistic">
      <div class="deng-home-container">
        <p class="deng-home-eyebrow">Live Network</p>
        <div class="deng-home-stat-grid deng-home-stat-grid--live" data-home-live-stats-grid>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="trackedPlayers">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Tracked Players</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="trackedPlayers" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Across All Games</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact deng-home-stat-card--status-green" data-home-stat-card="onlineNow">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Online Now</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value deng-home-stat-card__value--status-green js-count-up" data-home-stat-value="onlineNow" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta" data-home-stat-meta="onlineNow">Tracked usernames online</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact deng-home-stat-card--status-green" data-home-stat-card="rejoinActiveDevices">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Active Devices</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 8V4H8"></path><rect x="4" y="8" width="16" height="12" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value deng-home-stat-card__value--split-ratio" aria-label="Active rejoin devices">
              <span class="deng-home-stat-ratio-active js-count-up" data-home-stat-value="rejoinActiveDevices" data-count-format="integer" data-count-duration="1200">0</span><span class="deng-home-stat-ratio-sep"> / </span><span class="deng-home-stat-ratio-total js-count-up" data-home-stat-value="rejoinTotalDevices" data-count-format="integer" data-count-duration="1200">0</span>
            </strong>
            <span class="deng-home-stat-card__meta">Rejoin agents active</span>
          </article>
        </div>
        <p class="deng-home-stats-empty" data-home-live-stats-empty hidden>No live tracker stats available right now.</p>
      </div>
    </section>

    <section class="deng-home-section deng-home-section--stats deng-home-section--tight deng-home-anchor" id="platform" aria-labelledby="home-platform-title" data-home-section="platform">
      <div class="deng-home-container">
        <p class="deng-home-eyebrow">Platform Stats</p>
        <div class="deng-home-stat-grid deng-home-stat-grid--platform" data-home-platform-stats-grid>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="discordUsers">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Platform Players</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M7.5 14.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"></path><path d="M16.5 14.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"></path><path d="M10.8 12.2 21 2"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="discordUsers" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Linked dashboard accounts</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="generatedKeys">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">License Keys</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="generatedKeys" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Generated license keys</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="redeemedKeys">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Redeemed Keys</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="redeemedKeys" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Activated license keys</span>
          </article>
        </div>
        <p class="deng-home-stats-empty" data-home-platform-stats-empty hidden>Platform stats unavailable.</p>
      </div>
    </section>

    <section class="deng-home-section deng-home-section--stats deng-home-section--tight deng-home-anchor" id="fishit-stats" aria-labelledby="home-fishit-title" data-home-section="fishit">
      <div class="deng-home-container">
        <p class="deng-home-eyebrow">Fish It Stats</p>
        <div class="deng-home-stat-grid deng-home-stat-grid--fishit" data-home-fishit-stats-grid>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="caught24Hours">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">24 Hours Caught</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M6.5 12c.94-3.46 4.94-6 8.5-6 3.56 0 6.06 2.54 7 6-.94 3.47-3.44 6-7 6s-7.56-2.53-8.5-6Z"></path><path d="M18 12v.5"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="caught24Hours" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Fish caught yesterday</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="totalSecret">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Total Secret</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 2 2 7l10 5 10-5-10-5Z"></path><path d="m2 17 10 5 10-5"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="totalSecret" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Secret fish caught</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="totalForgotten">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Total Forgotten</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4"></path><path d="M12 16h.01"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="totalForgotten" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Forgotten fish caught</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="ghostfinnRod">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Ghostfinn Rod</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M3 21 21 3"></path><path d="M6 18 18 6"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="ghostfinnRod" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Ghostfinn Rod owners / records</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="elementRod">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Element Rod</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="elementRod" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Element Rod owners / records</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--compact" data-home-stat-card="diamondRod">
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Diamond Rod</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M6 3h12l4 7-10 13L2 10z"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value js-count-up" data-home-stat-value="diamondRod" data-count-format="integer" data-count-duration="1200">0</strong>
            <span class="deng-home-stat-card__meta">Diamond Rod owners / records</span>
          </article>
        </div>
        <p class="deng-home-stats-empty" data-home-fishit-stats-empty hidden>Fish It stats unavailable.</p>
      </div>
    </section>

    <section class="deng-home-section deng-home-anchor" id="about" aria-labelledby="home-ecosystem-title" data-home-section="about">
      <div class="deng-home-container">
        <p class="deng-home-eyebrow">Ecosystem</p>
        <h2 id="home-ecosystem-title" class="deng-home-section__title">One platform. Multiple modules.</h2>
        <p class="deng-home-section__lead">Each module lives in one account — pick what you need, sign in once.</p>
        <div class="deng-home-eco-grid">
          <article class="deng-home-eco-card deng-home-eco-card--featured">
            <div class="deng-home-eco-card__head">
              <span class="deng-home-eco-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M3 3v18h18"></path><path d="M7 16V9"></path><path d="M12 16V5"></path><path d="M17 16v-6"></path></svg>
              </span>
              <span class="deng-home-eco-card__badge">Current</span>
            </div>
            <h3>FishTracker &amp; Inventory</h3>
            <p>Real-time fish and inventory tracking, global catalog, leaderstats, and live dashboards.</p>
            <a class="deng-home-eco-link" href="/login?return=/inventory">Open tracker/dashboard →</a>
          </article>
          <article class="deng-home-eco-card">
            <div class="deng-home-eco-card__head">
              <span class="deng-home-eco-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 1 1-2.64-6.36"></path><polyline points="21 3 21 9 15 9"></polyline></svg>
              </span>
            </div>
            <h3>Auto Rejoin Agent</h3>
            <p>Keep Roblox sessions alive and reconnect automatically with your configured agents.</p>
            <a class="deng-home-eco-link" href="/login?return=/download">Visit agent →</a>
          </article>
          <article class="deng-home-eco-card">
            <div class="deng-home-eco-card__head">
              <span class="deng-home-eco-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              </span>
            </div>
            <h3>License &amp; Discord Hub</h3>
            <p>Key management, Discord login, and your signed-in user dashboard.</p>
            <a class="deng-home-eco-link" href="/login?return=/dashboard">Open dashboard →</a>
          </article>
        </div>
      </div>
    </section>
  </main>

  <footer class="deng-home-footer">
    <div class="deng-home-container deng-home-footer__inner">
      <div class="deng-home-footer__brand">DENG All In One</div>
      <nav class="deng-home-footer__links" aria-label="Footer">
        <a href="#home">Home</a>
        <a href="#statistic">Statistic</a>
        <a href="#about">About</a>
        <a href="/login">Sign In</a>
        <a href="https://discord.gg/v74u5ZtuXf" target="_blank" rel="noopener noreferrer">Discord</a>
      </nav>
    </div>
  </footer>
</div>

