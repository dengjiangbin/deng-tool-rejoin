        <p class="deng-home-eyebrow">Live Network</p>
        <div class="deng-home-stat-grid" data-home-stats-grid>
          <article class="deng-home-stat-card" data-home-stat-card="trackedPlayers" hidden>
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Tracked Players</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value" data-home-stat-value="trackedPlayers">—</strong>
            <span class="deng-home-stat-card__meta">Across all tracked games</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--accent" data-home-stat-card="onlineNow" hidden>
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Online Now</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value deng-home-stat-card__value--accent" data-home-stat-value="onlineNow">—</strong>
            <span class="deng-home-stat-card__meta" data-home-stat-meta="onlineNow">Active devices online</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--accent" data-home-stat-card="activeAgents" hidden>
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Active Agents</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M12 8V4H8"></path><rect x="4" y="8" width="16" height="12" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value deng-home-stat-card__value--accent" data-home-stat-value="activeAgents">—</strong>
            <span class="deng-home-stat-card__meta">Rejoin bots running</span>
          </article>
          <article class="deng-home-stat-card" data-home-stat-card="totalFish" hidden>
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Fish Tracked</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M6.5 12c.94-3.46 4.94-6 8.5-6 3.56 0 6.06 2.54 7 6-.94 3.47-3.44 6-7 6s-7.56-2.53-8.5-6Z"></path><path d="M18 12v.5"></path><path d="M16 17.93a9.77 9.77 0 0 1 0-11.86"></path><path d="M7 10.67C7 8 5.58 5.97 2.73 5.5c-1 1.5-1 5 .23 6.5-1.24 1.5-1.24 5-.23 6.5C5.58 18.03 7 16 7 13.33"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value" data-home-stat-value="totalFish">—</strong>
            <span class="deng-home-stat-card__meta">Fish It global catalog</span>
          </article>
          <article class="deng-home-stat-card" data-home-stat-card="uniqueUsers" hidden>
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">Discord Users</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M3 3v18h18"></path><path d="M7 16V9"></path><path d="M12 16V5"></path><path d="M17 16v-6"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value" data-home-stat-value="uniqueUsers">—</strong>
            <span class="deng-home-stat-card__meta">Linked dashboard accounts</span>
          </article>
          <article class="deng-home-stat-card deng-home-stat-card--warn" data-home-stat-card="generatedKeys" hidden>
            <div class="deng-home-stat-card__top">
              <span class="deng-home-stat-card__label">License Keys</span>
              <span class="deng-home-stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="m9 12 2 2 4-4"></path><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path></svg>
              </span>
            </div>
            <strong class="deng-home-stat-card__value deng-home-stat-card__value--warn" data-home-stat-value="generatedKeys">—</strong>
            <span class="deng-home-stat-card__meta">Generated license keys</span>
          </article>
        </div>
        <p class="deng-home-stats-empty" data-home-stats-empty hidden>No live stats available right now. The page will keep working — check back soon.</p>
      </div>
    </section>

    <section class="deng-home-section deng-home-section--network" aria-labelledby="home-network-title">
      <div class="deng-home-container">
        <div class="deng-home-network-panel">
          <div class="deng-home-network-panel__head">
            <div class="deng-home-network-panel__title-wrap">
              <span class="deng-home-network-panel__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="8" rx="2"></rect><rect x="2" y="14" width="20" height="8" rx="2"></rect><path d="M6 6h.01"></path><path d="M6 18h.01"></path></svg>
              </span>
              <div>
                <p class="deng-home-eyebrow deng-home-eyebrow--inline">Tool Network</p>
                <h2 id="home-network-title" class="deng-home-network-panel__title">Agent Network</h2>
