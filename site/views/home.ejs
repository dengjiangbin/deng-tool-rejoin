<div class="deng-home" id="top">
  <div class="deng-home-nav-wrap">
    <header class="deng-home-nav" aria-label="Site navigation">
      <div class="deng-home-nav__inner">
        <a class="deng-home-brand" href="/" aria-label="Go to home">
