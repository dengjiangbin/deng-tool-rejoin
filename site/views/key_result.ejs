<% locals.activePage = 'license' %>

<div class="key-result-page" data-portal-step="key-result">
  <section class="key-result-card">
    <div class="key-success-logo">
      <img src="/public/img/deng-logo.png?v=<%= assetVersion %>" alt="DENG All In One" class="result-logo-img">
    </div>
    <h1 class="key-result-title"><%= recoveredExisting ? 'Your Unused Key' : 'Your Key Is Ready' %></h1>
    <p class="key-result-desc">
      <% if (recoveredExisting) { %>
        You already have an unused key. Copy or redeem this key before generating another one.
      <% } else { %>
        Copy the key below. The key is server-rendered for your authorized session and is not stored in the URL.
      <% } %>
    </p>

    <div class="key-display-wrap">
      <code class="key-display" id="key-value"><%= key %></code>
      <button class="btn-copy" id="btn-copy" type="button" data-copy-key data-key="<%= key %>" aria-label="Copy key">
        Copy
      </button>
    </div>

    <div class="instruction-card">
      <p>Redeem this key inside the Rejoin module to activate your license.</p>
      <p>This key expires if not redeemed within 24 hours.</p>
      <p>Open Rejoin, paste this license key, then continue setup.</p>
    </div>

    <div class="key-actions">
      <a href="/license" class="btn btn-outline">Back to My License</a>
      <a href="/dashboard" class="btn btn-primary">Dashboard</a>
    </div>
  </section>
</div>
