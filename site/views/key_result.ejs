<% locals.activePage = 'license' %>

<div class="key-result-page" data-portal-step="key-result">
  <section class="key-result-card">
    <div class="key-success-logo">
      <img src="/public/img/deng-logo.png?v=<%= assetVersion %>" alt="DENG Tool" class="result-logo-img">
    </div>
    <h1 class="key-result-title">Your Key Is Ready</h1>
    <p class="key-result-desc">
      Copy the key below. The key is server-rendered for your authorized session and is not stored in the URL.
    </p>

    <div class="key-display-wrap">
      <code class="key-display" id="key-value"><%= key %></code>
      <button class="btn-copy" id="btn-copy" data-key="<%= key %>" onclick="copyKey(this)" aria-label="Copy key">
        Copy
      </button>
    </div>

    <div class="instruction-card">
      <p>Redeem this key inside DENG Tool: Rejoin to use the tool.</p>
      <p>This key expires if not redeemed within 24 hours.</p>
      <p>Open DENG Tool: Rejoin, paste this license key, then continue setup.</p>
    </div>

    <div class="key-actions">
      <a href="/license" class="btn btn-outline">Back to My License</a>
      <a href="/dashboard" class="btn btn-primary">Dashboard</a>
    </div>
  </section>
</div>

<script>
function copyKey(btn) {
  var key = btn.dataset.key;
  navigator.clipboard.writeText(key).then(function() {
    btn.textContent = 'Copied';
    btn.classList.add('copied');
    setTimeout(function() {
      btn.textContent = 'Copy';
      btn.classList.remove('copied');
    }, 2200);
  }).catch(function() {
    btn.textContent = 'Copy manually';
  });
}
</script>
