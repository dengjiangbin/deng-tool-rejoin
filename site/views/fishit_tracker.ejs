<!DOCTYPE html>
<html lang="en" data-theme="dark" data-render-build="<%= typeof renderBuild !== 'undefined' ? renderBuild : 'BLOCKER10Z7_METADATA_SPECIES_EXTRACTION_2026_06_08' %>" data-public-api-build="<%= typeof publicApiBuild !== 'undefined' ? publicApiBuild : 'BLOCKER10Z7_METADATA_SPECIES_EXTRACTION_2026_06_08' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>&#x1F3A3; Fish It Live Inventory Tracker</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0f14;
      --surface:   #161a22;
      --surface2:  #1e2430;
      --border:    #2a3040;
      --accent:    #3b82f6;
      --accent2:   #60a5fa;
      --text:      #e2e8f0;
      --muted:     #8a94a6;
      --danger:    #ef4444;
      --success:   #22c55e;
      --warn:      #f59e0b;
      --shine:     #fbbf24;
      --radius:    10px;
      --radius-lg: 16px;
      --font:      'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    html, body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 15px;
      line-height: 1.5;
    }

    .page { min-height:100vh; display:flex; flex-direction:column; align-items:center; padding:32px 16px 64px; }
    .inner { width:100%; max-width:1040px; }

    .back-link { display:inline-flex; align-items:center; gap:6px; color:var(--muted); text-decoration:none; font-size:.85rem; margin-bottom:24px; transition:color .15s; }
    .back-link:hover { color:var(--accent2); }

    .header { text-align:center; margin-bottom:28px; }
    .header h1 { font-size:clamp(1.5rem,4vw,2.2rem); font-weight:700; background:linear-gradient(135deg,#3b82f6,#60a5fa,#93c5fd); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; letter-spacing:-.5px; margin-bottom:6px; }
    .header p { color:var(--muted); font-size:.9rem; }

    .add-row { display:flex; gap:10px; margin-bottom:20px; }
    .add-row input { flex:1; padding:12px 16px; background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius); color:var(--text); font-size:.95rem; font-family:var(--font); outline:none; transition:border-color .15s; }
    .add-row input:focus { border-color:var(--accent); }
    .add-row input::placeholder { color:var(--muted); }

    .btn { padding:12px 22px; border-radius:var(--radius); border:none; cursor:pointer; font-size:.9rem; font-weight:600; font-family:var(--font); transition:opacity .15s,transform .1s; white-space:nowrap; }
    .btn:active { transform:scale(.97); }
    .btn-primary { background:linear-gradient(135deg,#3b82f6,#2563eb); color:#fff; }
    .btn-primary:hover { opacity:.9; }

    .summary-bar { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; font-size:.85rem; color:var(--muted); }
    .summary-bar strong { color:var(--text); }

    .no-trackers { text-align:center; padding:60px 20px; color:var(--muted); border:1.5px dashed var(--border); border-radius:var(--radius-lg); margin-bottom:24px; }
    .no-trackers .icon { font-size:2.5rem; margin-bottom:10px; }
    .no-trackers p { font-size:.9rem; }

    .tracker-card { background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius-lg); margin-bottom:14px; overflow:hidden; animation:slideIn .2s ease; transition:border-color .25s; }
    .tracker-card.state-live    { border-color:var(--success); }
    .tracker-card.state-waiting { border-color:var(--warn); }
    .tracker-card.state-error   { border-color:var(--danger); }

    @keyframes slideIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

    .card-head { display:flex; align-items:center; gap:12px; padding:14px 16px; cursor:pointer; user-select:none; }
    .card-head:hover { background:var(--surface2); }

    .dot { width:9px; height:9px; border-radius:50%; flex-shrink:0; background:var(--muted); transition:background .2s; }
    .state-live    .dot { background:var(--success); animation:pulse 1.4s ease-in-out infinite; }
    .state-waiting .dot { background:var(--warn);    animation:pulse 1.4s ease-in-out infinite; }
    .state-error   .dot { background:var(--danger); }

    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }

    .card-username { font-weight:700; font-size:1rem; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .card-meta-row { display:flex; align-items:center; gap:10px; font-size:.8rem; color:var(--muted); flex-shrink:0; }

    .pill { padding:3px 10px; border-radius:99px; background:var(--surface2); border:1px solid var(--border); font-size:.78rem; color:var(--muted); white-space:nowrap; }
    .pill strong { color:var(--text); }

    .chevron { width:16px; height:16px; color:var(--muted); transition:transform .2s; flex-shrink:0; }
    .tracker-card.expanded .chevron { transform:rotate(180deg); }

    .btn-remove { background:none; border:1px solid var(--border); border-radius:var(--radius); color:var(--muted); cursor:pointer; padding:4px 10px; font-size:.78rem; font-family:var(--font); transition:color .15s,border-color .15s,background .15s; flex-shrink:0; }
    .btn-remove:hover { color:var(--danger); border-color:var(--danger); background:#1a0808; }

    .card-status-line { padding:0 16px 10px; font-size:.8rem; color:var(--muted); }

    .card-body { padding:0 16px 16px; display:none; }
    .tracker-card.expanded .card-body { display:block; }

    .items-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; margin-top:4px; }

    .item-card, .fish-card { border:0; border-radius:12px; padding:12px; min-height:118px; display:flex; flex-direction:column; gap:8px; color:#fff; box-shadow:0 10px 24px rgba(0,0,0,.22); overflow:hidden; transition:transform .15s,box-shadow .2s; animation:fadeIn .2s ease; }
    .item-card:hover, .fish-card:hover { transform:translateY(-2px); box-shadow:0 14px 28px rgba(0,0,0,.28); }
    .item-card.rarity-common, .fish-card.rarity-common { background:linear-gradient(135deg,#242936 0%,#141820 100%); }
    .item-card.rarity-uncommon, .fish-card.rarity-uncommon { background:linear-gradient(135deg,#2a3440 0%,#1a2030 100%); }
    .item-card.rarity-rare, .fish-card.rarity-rare { background:linear-gradient(135deg,#60b4ff 0%,#3d88dc 100%); }
    .item-card.rarity-epic, .fish-card.rarity-epic { background:linear-gradient(135deg,#b879ff 0%,#8152d6 100%); }
    .item-card.rarity-legendary, .fish-card.rarity-legendary { background:linear-gradient(135deg,#ffc936 0%,#d79413 100%); }
    .item-card.rarity-mythic, .fish-card.rarity-mythic { background:linear-gradient(135deg,#ff2525 0%,#c90d12 100%); }
    .item-card.rarity-secret, .fish-card.rarity-secret { background:linear-gradient(135deg,#10e487 0%,#09c96f 55%,#079b59 100%); }
    .item-card.rarity-forgotten, .fish-card.rarity-forgotten { background:linear-gradient(135deg,#f0f0f0 0%,#777 50%,#111 100%); }
    .item-card:not([class*="rarity-"]), .fish-card:not([class*="rarity-"]) { background:linear-gradient(135deg,#242936 0%,#141820 100%); border:1px solid var(--border); }

    .item-card .item-name, .fish-card .item-name { color:#fff; text-shadow:0 1px 2px rgba(0,0,0,.35); }
    .item-card .ic-meta .badge, .fish-card .ic-meta .badge { background:rgba(0,0,0,.35); border-color:rgba(255,255,255,.25); color:#fff; }
    .item-card .ic-badges span[style], .fish-card .ic-badges span[style] { background:rgba(0,0,0,.35)!important; border-color:rgba(255,255,255,.2)!important; color:#fff!important; }
    .item-card .ic-head img, .fish-card .ic-head img { background:rgba(0,0,0,.25)!important; box-shadow:0 2px 8px rgba(0,0,0,.25); }

    @keyframes fadeIn { from{opacity:0;transform:translateY(5px)} to{opacity:1;transform:translateY(0)} }

    .ic-head { display:flex; align-items:center; gap:8px; flex-wrap:nowrap; }
    .ic-title-wrap { flex:1; min-width:0; display:flex; flex-direction:column; gap:4px; }
    .item-name { font-weight:600; font-size:.9rem; line-height:1.35; min-width:0; word-break:normal; overflow-wrap:break-word; white-space:normal; display:block; overflow:hidden; text-overflow:ellipsis; }
    .global-db-proof { margin-top:8px; border:1px solid var(--border); border-radius:var(--radius); background:var(--surface2); }
    .global-db-proof summary { cursor:pointer; padding:8px 10px; font-size:.78rem; color:#93c5fd; user-select:none; }
    .global-db-proof .gdb-body { padding:8px 10px 10px; font-size:.74rem; color:var(--muted); line-height:1.45; }
    .global-db-proof .gdb-row { display:flex; justify-content:space-between; gap:8px; }
    .global-db-proof .gdb-on { color:#4ade80; font-weight:600; }
    .global-db-debug { margin-top:6px; font-size:.68rem; color:#8a94a6; max-height:120px; overflow:auto; }
    .ic-badges { display:flex; flex-wrap:wrap; gap:4px; align-items:center; flex-shrink:0; margin-top:2px; }
    .ic-meta { display:flex; flex-wrap:wrap; gap:5px; }
    .badge { font-size:.72rem; padding:2px 9px; border-radius:99px; border:1px solid var(--border); background:var(--surface); color:var(--muted); }
    .badge-weight  { color:var(--accent2); border-color:#1d3a5c; background:#0d1f30; }
    .rarity-common    { color:var(--muted); }
    .rarity-uncommon  { color:#4ade80;  border-color:#143d20; background:#091a0f; }
    .rarity-rare      { color:#60a5fa;  border-color:#1d3a5c; background:#0d1f30; }
    .rarity-epic      { color:#c084fc;  border-color:#3d1f5e; background:#1a0f2e; }
    .rarity-legendary { color:var(--shine); border-color:#7a5a00; background:#3d2c00; }
    .rarity-secret, .badge-rarity-secret { color:#22d3ee; border-color:#0e7490; background:#042f2e; }
    .rarity-forgotten { color:#818cf8;  border-color:#1e1e5c; background:#0d0d30; }

    .card-empty { text-align:center; padding:24px; color:var(--muted); font-size:.85rem; }

    .loadstring-box { margin-top:36px; background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:20px; }
    .loadstring-box h3 { font-size:.8rem; color:var(--muted); text-transform:uppercase; letter-spacing:.06em; margin-bottom:12px; }
    .code-row { display:flex; gap:8px; align-items:stretch; }
    .code-block { flex:1; font-family:'Consolas','Fira Code',monospace; font-size:.82rem; background:#0a0c10; border:1px solid var(--border); border-radius:var(--radius); padding:12px 14px; color:#93c5fd; overflow-x:auto; white-space:nowrap; }
    .btn-copy { padding:0 16px; background:var(--surface2); border:1.5px solid var(--border); border-radius:var(--radius); color:var(--text); cursor:pointer; font-size:.85rem; font-family:var(--font); font-weight:600; white-space:nowrap; transition:background .15s,border-color .15s,color .15s; }
    .btn-copy:hover  { background:var(--accent); border-color:var(--accent); color:#fff; }
    .btn-copy.copied { background:var(--success); border-color:var(--success); color:#fff; }

    @media (max-width:560px) {
      .add-row { flex-wrap:wrap; }
      .btn { width:100%; }
      .code-row { flex-direction:column; }
      .btn-copy { padding:10px; }
      .card-meta-row { gap:6px; }
    }
  </style>
</head>
<body data-ui-marker="BLOCKER10Z9_PUBLIC_SNAPSHOT_TRUTH_AND_FULL_RARITY_CARDS_2026_06_08">
<!-- BLOCKER10Z9_PUBLIC_SNAPSHOT_TRUTH_AND_FULL_RARITY_CARDS_2026_06_08 -->
<div class="page">
  <div class="inner">

    <a href="/" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      Back to DENG Tool
    </a>

    <header class="header">
      <h1>&#x1F3A3; Fish It Live Inventory Tracker</h1>
      <p>Track unlimited players simultaneously � sessions are saved and restored on page reload.</p>
    </header>

    <div class="add-row">
      <input type="text" id="usernameInput" placeholder="Enter Roblox Username..." maxlength="20" autocomplete="off" spellcheck="false" aria-label="Roblox username">
      <button class="btn btn-primary" id="addBtn" type="button">+ Add Tracker</button>
    </div>

    <div class="summary-bar">
      <span id="summaryText">No active trackers</span>
    </div>

    <div id="trackerList"></div>

    <div class="no-trackers" id="noTrackersMsg">
      <div class="icon">&#x1F3A3;</div>
      <p>Add a Roblox username above to start live tracking.<br>Sessions are saved automatically and restored on page reload.</p>
    </div>

    <div class="loadstring-box">
      <h3>Executor Script � copy &amp; run in-game</h3>
      <div class="code-row">
        <div class="code-block" id="loadstringCode">loadstring(game:HttpGet("https://raw.githubusercontent.com/dengjiangbin/deng-tool-rejoin/main/tracker.lua?t=" .. tostring(os.time())))()</div>
        <button class="btn-copy" id="copyBtn" type="button">Copy</button>
      </div>
    </div>

  </div>
</div>
<script>
(function () {
  'use strict';

  const LS_KEY        = 'fishit_tracked_users';
  const POLL_MS       = 5000;
  const DEBUG_GLOBAL  = /(?:^|[?&])debug=global(?:&|$)/.test(window.location.search);
  const RENDER_BUILD  = document.documentElement.getAttribute('data-render-build')
    || 'BLOCKER10Z7_METADATA_SPECIES_EXTRACTION_2026_06_08';
  const PUBLIC_API_BUILD = document.documentElement.getAttribute('data-public-api-build')
    || 'BLOCKER10Z7_METADATA_SPECIES_EXTRACTION_2026_06_08';
  const RARITY_NAME_COLORS = {
    common:'#9ca3af', uncommon:'#4ade80', rare:'#60a5fa', epic:'#c084fc',
    legendary:'#eab308', legend:'#eab308', mythic:'#f472b6', secret:'#22d3ee', forgotten:'#818cf8',
  };
  const RARITY_MAP = { common:'rarity-common', uncommon:'rarity-uncommon', rare:'rarity-rare', epic:'rarity-epic', legendary:'rarity-legendary', legend:'rarity-legendary', mythic:'rarity-mythic', secret:'rarity-secret badge-rarity-secret', forgotten:'rarity-forgotten' };
  const CARD_RARITY_MAP = { common:'rarity-common', uncommon:'rarity-uncommon', rare:'rarity-rare', epic:'rarity-epic', legendary:'rarity-legendary', legend:'rarity-legendary', mythic:'rarity-mythic', secret:'rarity-secret', forgotten:'rarity-forgotten' };

  const trackers       = new Map();
  const inputEl        = document.getElementById('usernameInput');
  const addBtn         = document.getElementById('addBtn');
  const trackerListEl  = document.getElementById('trackerList');
  const noTrackersMsg  = document.getElementById('noTrackersMsg');
  const summaryTextEl  = document.getElementById('summaryText');
  const copyBtn        = document.getElementById('copyBtn');

  function loadSaved() { try { return JSON.parse(localStorage.getItem(LS_KEY) || '[]'); } catch { return []; } }
  function saveCurrent() { try { localStorage.setItem(LS_KEY, JSON.stringify([...trackers.keys()])); } catch {} }

  function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function fmtTime(iso) {
    if (!iso) return '-';
    try {
      return new Date(iso).toLocaleTimeString('en-GB', {
        timeZone: 'Asia/Jakarta', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
      }) + ' WIB';
    } catch { return '-'; }
  }
  function syncTimestamp(data) {
    return data && (data.lastInventoryAt || data.lastSeenAt || data.updatedAt) || null;
  }
  /** Public fish-only list (BLOCKER10K1). Never reads mixed enrichedItems or full inventory groups. */
  function getPublicFishItems(data) {
    if (!data) return [];
    if (Array.isArray(data.fishItems)) return data.fishItems;
    if (Array.isArray(data.publicItems)) return data.publicItems;
    if (data.fishInventory && Array.isArray(data.fishInventory.fish)) return data.fishInventory.fish;
    if (data.renderBuild === RENDER_BUILD && Array.isArray(data.items)) {
      return data.items.filter((it) => String(it.category || '').toLowerCase() === 'fish');
    }
    return [];
  }
  function logFishOnlyRender(key, data, fishList) {
    if (!data || data.renderBuild !== RENDER_BUILD) return;
    const entry = trackers.get(key);
    if (!entry || entry._loggedK1) return;
    entry._loggedK1 = true;
    const fc = data.fishCounts;
    console.log(
      `[fishit-tracker-ui] renderBuild=${RENDER_BUILD} fishItems=${fishList.length}` +
      ` hiddenNonFishTypes=${fc && fc.hiddenNonFishTypes != null ? fc.hiddenNonFishTypes : '?'}`
    );
  }
  function fishCountLabel(data, fishList) {
    const fc = data && data.fishCounts;
    const pc = data && data.publicCounts;
    const types = (pc && pc.visibleFishTypes != null) ? pc.visibleFishTypes
      : ((fc && fc.fishTypes != null) ? fc.fishTypes : fishList.length);
    const fishTotal = (pc && pc.visibleFishInstances != null) ? pc.visibleFishInstances
      : ((fc && fc.fishInstances != null) ? fc.fishInstances : null);
    if (fishTotal != null) {
      return `Tracked fish: <strong>${fishTotal}</strong> &middot; Types: <span style="color:#8a94a6;">${types}</span>`;
    }
    return `Types: <strong>${types}</strong>`;
  }
  function buildGlobalDbProofHtml(data) {
    if (!DEBUG_GLOBAL) return '';
    const g = (data && data.globalDbUiProof) || (data && data.globalCatalogProof) || null;
    if (!g) return '';
    const imgLabel = g.cardsUsingGlobalDbImagesLabel
      || `${g.cardsUsingGlobalDbImages || 0}/${g.cardsTotal || '?'}`;
    const rarLabel = g.cardsUsingGlobalDbRarityLabel
      || `${g.cardsUsingGlobalDbRarity || 0}/${g.cardsTotal || '?'}`;
    let debugRows = '';
    if (Array.isArray(data.publicFishItems)) {
      debugRows = data.publicFishItems.slice(0, 12).map((it) =>
        `<div>${escHtml(it.canonicalName || it.name)} &mdash; img:${escHtml(it.dataImageSource || it.imageSource || '-')} rarity:${escHtml(it.dataRaritySource || it.raritySource || '-')}</div>`
      ).join('');
    }
    let parityRows = '';
    const rp = data.replionCountProof || data.countParityProof;
    if (rp) {
      parityRows = `<div class="global-db-debug">Replion: snapshot=${rp.snapshotItemInstances || rp.fullSnapshotItemInstances || '?'} fish=${rp.fishCandidates || rp.fullSnapshotFishCandidates || '?'} shown=${rp.publicFishInstances || rp.groupedPublicInstances || '?'} unmapped=${rp.unmappedFishCandidates || rp.unmappedFishCandidateInstances || 0}</div>`;
    }
    let amountRows = '';
    const ap = data.amountProof;
    if (ap && Array.isArray(ap.rows)) {
      amountRows = `<div class="global-db-debug">amountProof verified=${ap.allVerified ? 'yes' : 'no'}${ap.rows.slice(0, 10).map((r) =>
        `<br>${escHtml(r.publicCardName || '?')} id=${escHtml(r.itemId || '-')} amt=${r.publicAmount} src=${escHtml(r.amountSource || '-')} catalog=${escHtml(r.catalogName || '-')} final=${escHtml(r.finalName || '-')}`
      ).join('')}</div>`;
    }
    let ambiguousRows = '';
    const acp = (data && data.ambiguousContainerProof && typeof data.ambiguousContainerProof === 'object')
      ? data.ambiguousContainerProof : null;
    if (acp) {
      const ids = Array.isArray(data.ambiguousContainerIds) ? data.ambiguousContainerIds : [267];
      ambiguousRows = `<div class="global-db-debug">ambiguousContainerIds=${escHtml(JSON.stringify(ids))}<br>ambiguousContainerProof rowsSeen=${acp.rowsSeen != null ? acp.rowsSeen : 0} metaId=${acp.rowsWithMetadataFishId != null ? acp.rowsWithMetadataFishId : 0} metaName=${acp.rowsWithMetadataFishName != null ? acp.rowsWithMetadataFishName : 0} unresolved=${acp.rowsUnresolved != null ? acp.rowsUnresolved : 0}</div>`;
    }
    let hiddenRows = '';
    const hpr = data.hiddenPublicRows;
    const pc = data.publicCounts;
    if (hpr || pc) {
      hiddenRows = `<div class="global-db-debug">publicCounts visible=${pc && pc.visibleFishInstances != null ? pc.visibleFishInstances : '?'} types=${pc && pc.visibleFishTypes != null ? pc.visibleFishTypes : '?'} hiddenUnresolved=${pc && pc.hiddenUnresolvedFishRows != null ? pc.hiddenUnresolvedFishRows : '?'}${hpr ? `<br>hiddenPublicRows ambiguousUnresolved=${hpr.ambiguousContainerUnresolved != null ? hpr.ambiguousContainerUnresolved : 0} ids=${escHtml(JSON.stringify(hpr.hiddenItemIds || []))}` : ''}</div>`;
    }
    let quarantineRows = '';
    if (Array.isArray(data.quarantinedPublicNames) && data.quarantinedPublicNames.length) {
      quarantineRows = `<div class="global-db-debug">quarantinedPublicNames${data.quarantinedPublicNames.slice(0, 8).map((q) =>
        `<br>${escHtml(q.name || '?')} id=${escHtml(q.itemId || '-')} reason=${escHtml(q.reason || '-')}`
      ).join('')}</div>`;
    }
    let missingFishRows = '';
    const mfp = data.missingExpectedFishProof;
    if (mfp && mfp['Radiant Catfish']) {
      const r = mfp['Radiant Catfish'];
      missingFishRows = `<div class="global-db-debug">missingExpectedFishProof Radiant Catfish catalog=${r.foundInTrustedCatalog ? 'yes' : 'no'} matched=${r.currentSnapshotRowMatched ? 'yes' : 'no'} id=${escHtml(r.itemId || '-')} image=${r.imageResolved ? 'yes' : 'no'}</div>`;
    }
    let catchRows = '';
    const cl = data.catchLearningProof;
    if (cl) {
      catchRows = `<div class="global-db-debug">Catch learning: ${cl.catchEvidenceSupported ? 'ON' : 'OFF'}${cl.pendingCatch ? ` pending=${escHtml(cl.pendingCatch.fishName || '-')}` : ''}</div>`;
    }
    let rarityRows = '';
    if (Array.isArray(data.rarityColorProof) && data.rarityColorProof.length) {
      rarityRows = `<div class="global-db-debug">${data.rarityColorProof.slice(0, 8).map((r) =>
        escHtml(`${r.canonicalName || '?'}: ${r.finalRarity || 'unknown'} (${r.finalRaritySource || '-'})`)
      ).join('<br>')}</div>`;
    }
    return `<details class="global-db-proof" open>
  <summary>Global DB: <span class="gdb-on">ON</span> &mdash; ${escHtml(g.sourceOfTruth || 'global_db')} &mdash; images ${escHtml(imgLabel)}</summary>
  <div class="gdb-body">
    <div class="gdb-row"><span>Source</span><span>SQLite global_db</span></div>
    <div class="gdb-row"><span>Species</span><span>${g.speciesCount != null ? g.speciesCount : '?'}</span></div>
    <div class="gdb-row"><span>Mappings</span><span>${g.mappingCount != null ? g.mappingCount : '?'}</span></div>
    <div class="gdb-row"><span>Observations</span><span>${g.observationCount != null ? g.observationCount.toLocaleString('en-US') : '?'}</span></div>
    <div class="gdb-row"><span>Images</span><span>${g.imageAssetCount != null ? g.imageAssetCount : '?'}</span></div>
    <div class="gdb-row"><span>Cards w/ global image</span><span>${escHtml(imgLabel)}</span></div>
    <div class="gdb-row"><span>Cards w/ global rarity</span><span>${escHtml(rarLabel)}</span></div>
    ${parityRows}${amountRows}${ambiguousRows}${hiddenRows}${quarantineRows}${missingFishRows}${catchRows}${rarityRows}${debugRows ? `<div class="global-db-debug">${debugRows}</div>` : ''}
  </div>
</details>`;
  }
  function rarityNameStyle(item) {
    const r = item && item.rarity ? String(item.rarity).toLowerCase() : '';
    const accent = item.rarityAccentColor || RARITY_NAME_COLORS[r] || null;
    return accent ? `color:${accent};` : '';
  }
  function itemImageSrc(item) {
    if (isUsableImageUrl(item.imageUrl)) return item.imageUrl;
    if (item.imageAssetId && /^\d{10,22}$/.test(String(item.imageAssetId))) {
      return `/api/fishit-tracker/image/${item.imageAssetId}`;
    }
    return null;
  }
  function rarityClass(r) { return r ? (RARITY_MAP[r.toLowerCase()] || 'badge') : ''; }
  function cardRarityClass(r) { return r ? (CARD_RARITY_MAP[r.toLowerCase()] || '') : ''; }

  const ITEM_IMAGES = {
    // Add real hosted/local URLs here as they become available, e.g.
    // 'Cactus Pufferfish': '/assets/img/fishit/cactus-pufferfish.png',
    fish: '/assets/img/fishit/fallback-fish.svg',
    rod: '/assets/img/fishit/fallback-rod.svg',
    rods: '/assets/img/fishit/fallback-rod.svg',
    bait: '/assets/img/fishit/fallback-fish.svg',
    baits: '/assets/img/fishit/fallback-fish.svg',
    items: '/assets/img/fishit/fallback-secret.svg',
    item: '/assets/img/fishit/fallback-secret.svg',
    secret: '/assets/img/fishit/fallback-secret.svg',
    forgotten: '/assets/img/fishit/fallback-forgotten.svg',
    Default: '/assets/img/fishit/fallback-fish.svg'
  };

  function isUsableImageUrl(url) {
    if (!url || typeof url !== 'string') return false;
    const u = url.trim();
    if (!u) return false;
    if (/^\d{10,22}$/.test(u)) return false;
    if (/thumbnails\.roblox\.com/i.test(u)) return false;
    if (/create\.roblox\.com\/store\/asset\//i.test(u)) return false;
    if (u.startsWith('/api/fishit-tracker/image/')) return true;
    if (u.startsWith('/api/fishit-tracker/assets/fish/')) return true;
    if (u.startsWith('http')) return true;
    if (u.startsWith('/assets/')) return true;
    return false;
  }
  function onFishImageError(img, item) {
    console.warn('[fishit-tracker-ui] image load failed', {
      name: item && item.name,
      itemId: item && item.itemId,
      imageAssetId: item && item.imageAssetId,
      imageUrl: item && item.imageUrl,
      imageResolved: item && item.imageResolved,
      imageStatus: item && item.imageStatus,
      attempted: img && img.src,
    });
    img.onerror = null;
    img.src = ITEM_IMAGES.Default;
  }

  function updateSummary() {
    const n = trackers.size;
    if (n === 0) { summaryTextEl.textContent = 'No active trackers'; noTrackersMsg.style.display = 'block'; }
    else { summaryTextEl.innerHTML = `Tracking <strong>${n}</strong> player${n>1?'s':''} &mdash; sessions saved automatically`; noTrackersMsg.style.display = 'none'; }
  }

  function cardTitle(item) {
    return item.cardName || item.baseFishName || item.name || 'Unknown';
  }
  function cardKey(item) {
    const id = item.speciesId || item.itemId || item.canonicalName || item.baseFishName || item.name || 'unknown';
    const mut = (Array.isArray(item.mutationTags) && item.mutationTags[0]) || item.mutation || '';
    return `${String(id).toLowerCase()}|${String(mut).toLowerCase()}`;
  }
  function buildItemCardElement(item) {
    const isShiny = item.shiny === true;
    const rarity  = item.rarity && item.rarity !== 'Unknown' ? item.rarity : null;
    const rc      = rarityClass(rarity);
    const crc     = cardRarityClass(rarity);
    const rarityLow = rarity ? rarity.toLowerCase() : '';
    const amount  = Number(item.amount || 1);
    const title   = cardTitle(item);
    const imgSrc  = itemImageSrc(item) || ITEM_IMAGES.Default;
    const nameStyle = rarityNameStyle(item);
    const card = document.createElement('div');
    card.className = 'item-card fish-card';
    card.setAttribute('data-card-key', cardKey(item));
    if (item.dataSource) card.setAttribute('data-source', item.dataSource);
    if (item.dataImageSource) card.setAttribute('data-image-source', item.dataImageSource);
    if (item.dataRaritySource) card.setAttribute('data-rarity-source', item.dataRaritySource);
    if (item.mutation) card.setAttribute('data-mutation', item.mutation);
    if (isShiny) card.setAttribute('data-shiny', 'true');
    if (rarityLow) card.setAttribute('data-rarity', rarityLow);
    if (crc) card.classList.add(crc);
    if (isShiny && rarityLow !== 'secret') card.classList.add('shiny');
    const qty = `<span style="padding:1px 6px;border-radius:4px;font-size:.75em;background:#0a0c10;color:#e2e8f0;border:1px solid #2a3040;">x${Number.isFinite(amount) ? amount : 1}</span>`;
    const mutTags = Array.isArray(item.mutationTags) && item.mutationTags.length
      ? item.mutationTags.map(m => `<span class="badge" style="font-size:.68rem;">${escHtml(m)}</span>`).join('')
      : (item.mutation ? `<span class="badge" style="font-size:.68rem;">${escHtml(item.mutation)}</span>` : '');
    card.innerHTML = `
  <div class="ic-head"><img src="${escHtml(imgSrc)}" alt="${escHtml(title)}" decoding="async" style="width:28px;height:28px;border-radius:6px;object-fit:cover;background:#2a3040;flex-shrink:0;" data-item-id="${escHtml(item.itemId || '')}" data-asset-id="${escHtml(item.imageAssetId || '')}"><div class="ic-title-wrap"><span class="item-name" style="${nameStyle}">${escHtml(title)}</span><div class="ic-badges">${qty}${mutTags}</div></div></div>
  <div class="ic-meta">${rarity ? `<span class="badge ${rc}">${escHtml(rarity)}</span>` : ''}</div>`;
    const img = card.querySelector('img');
    if (img) img.onerror = () => onFishImageError(img, item);
    return card;
  }
  function patchItemCardElement(card, item) {
    const isShiny = item.shiny === true;
    const rarity  = item.rarity && item.rarity !== 'Unknown' ? item.rarity : null;
    const crc     = cardRarityClass(rarity);
    const rarityLow = rarity ? rarity.toLowerCase() : '';
    const title   = cardTitle(item);
    const imgSrc  = itemImageSrc(item) || ITEM_IMAGES.Default;
    card.setAttribute('data-card-key', cardKey(item));
    card.className = 'item-card fish-card';
    if (crc) card.classList.add(crc);
    if (isShiny && rarityLow !== 'secret') card.classList.add('shiny');
    if (item.mutation) card.setAttribute('data-mutation', item.mutation);
    else card.removeAttribute('data-mutation');
    if (isShiny) card.setAttribute('data-shiny', 'true');
    else card.removeAttribute('data-shiny');
    if (rarityLow) card.setAttribute('data-rarity', rarityLow);
    else card.removeAttribute('data-rarity');
    if (item.dataSource) card.setAttribute('data-source', item.dataSource);
    else card.removeAttribute('data-source');
    if (item.dataImageSource) card.setAttribute('data-image-source', item.dataImageSource);
    else card.removeAttribute('data-image-source');
    if (item.dataRaritySource) card.setAttribute('data-rarity-source', item.dataRaritySource);
    else card.removeAttribute('data-rarity-source');
    const nameEl = card.querySelector('.item-name');
    const nameStyle = rarityNameStyle(item);
    if (nameEl) {
      nameEl.textContent = title;
      nameEl.style.cssText = nameStyle;
    }
    const amount = Number(item.amount || 1);
    const qtyEl = card.querySelector('.ic-badges span[style]');
    if (qtyEl) qtyEl.textContent = `x${Number.isFinite(amount) ? amount : 1}`;
    const metaEl = card.querySelector('.ic-meta');
    if (metaEl) {
      const rc = rarityClass(rarity);
      metaEl.innerHTML = rarity ? `<span class="badge ${rc}">${escHtml(rarity)}</span>` : '';
    }
    let img = card.querySelector('img');
    if (!img) {
      const head = card.querySelector('.ic-head');
      if (head) {
        img = document.createElement('img');
        img.style.cssText = 'width:28px;height:28px;border-radius:6px;object-fit:cover;background:#2a3040;flex-shrink:0;';
        img.decoding = 'async';
        head.insertBefore(img, head.firstChild);
      }
    }
    if (img) {
      const currentSrc = img.getAttribute('src') || '';
      if (currentSrc !== imgSrc) {
        img.setAttribute('src', imgSrc);
      }
      img.alt = title;
      img.setAttribute('data-item-id', String(item.itemId || ''));
      img.setAttribute('data-asset-id', String(item.imageAssetId || ''));
      img.onerror = () => onFishImageError(img, item);
    }
  }
  function patchItemsGrid(container, items) {
    if (!items || items.length === 0) {
      if (!container.querySelector('.card-empty')) {
        container.innerHTML = '<div class="card-empty">&#x1F9F3; Inventory is empty.</div>';
      }
      return;
    }
    let grid = container.querySelector('.items-grid');
    if (!grid) {
      container.innerHTML = '<div class="items-grid"></div>';
      grid = container.querySelector('.items-grid');
    }
    const empty = container.querySelector('.card-empty');
    if (empty) empty.remove();
    const nextKeys = new Set();
    const existing = new Map();
    grid.querySelectorAll('.item-card[data-card-key]').forEach((el) => {
      existing.set(el.getAttribute('data-card-key'), el);
    });
    items.forEach((item, idx) => {
      const key = cardKey(item);
      nextKeys.add(key);
      let card = existing.get(key);
      if (!card) {
        card = buildItemCardElement(item);
        const ref = grid.children[idx] || null;
        grid.insertBefore(card, ref);
      } else {
        patchItemCardElement(card, item);
        const ref = grid.children[idx] || null;
        if (card !== ref) grid.insertBefore(card, ref);
      }
    });
    existing.forEach((el, key) => {
      if (!nextKeys.has(key)) el.remove();
    });
  }
  function buildItemsHtml(items) {
    if (!items || items.length === 0) return '<div class="card-empty">&#x1F9F3; Inventory is empty.</div>';
    return `<div class="items-grid">${items.map(item => {
      const isShiny = item.shiny === true;
      const rarity  = item.rarity && item.rarity !== 'Unknown' ? item.rarity : null;
      const rc      = rarityClass(rarity);
      const crc     = cardRarityClass(rarity);
      const rarityLow = rarity ? rarity.toLowerCase() : '';
      const amount  = Number(item.amount || 1);
      const title   = cardTitle(item);
      const qty     = `<span style="padding:1px 6px;border-radius:4px;font-size:.75em;background:#0a0c10;color:#e2e8f0;border:1px solid #2a3040;">x${Number.isFinite(amount) ? amount : 1}</span>`;
      const mutTags = Array.isArray(item.mutationTags) && item.mutationTags.length
        ? item.mutationTags.map(m => `<span class="badge" style="font-size:.68rem;">${escHtml(m)}</span>`).join('')
        : (item.mutation ? `<span class="badge" style="font-size:.68rem;">${escHtml(item.mutation)}</span>` : '');
      const imgSrc  = itemImageSrc(item) || ITEM_IMAGES.Default;
      const altText = escHtml(title);
      const cardCls = ['item-card', 'fish-card'];
      if (crc) cardCls.push(crc);
      if (isShiny && rarityLow !== 'secret') cardCls.push('shiny');
      const mutAttr = item.mutation ? ` data-mutation="${escHtml(item.mutation)}"` : '';
      const shinyAttr = isShiny ? ' data-shiny="true"' : '';
      const rarityAttr = rarityLow ? ` data-rarity="${escHtml(rarityLow)}"` : '';
      const srcAttr = item.dataSource ? ` data-source="${escHtml(item.dataSource)}"` : '';
      const imgSrcAttr = item.dataImageSource ? ` data-image-source="${escHtml(item.dataImageSource)}"` : '';
      const rarSrcAttr = item.dataRaritySource ? ` data-rarity-source="${escHtml(item.dataRaritySource)}"` : '';
      const nameStyle = rarityNameStyle(item);
      return `<div class="${cardCls.join(' ')}" data-card-key="${escHtml(cardKey(item))}"${mutAttr}${shinyAttr}${rarityAttr}${srcAttr}${imgSrcAttr}${rarSrcAttr}>
  <div class="ic-head"><img src="${escHtml(imgSrc)}" alt="${altText}" decoding="async" style="width:28px;height:28px;border-radius:6px;object-fit:cover;background:#2a3040;flex-shrink:0;" data-item-id="${escHtml(item.itemId || '')}" data-asset-id="${escHtml(item.imageAssetId || '')}" onerror="this.onerror=null;this.src='${ITEM_IMAGES.Default}';"><div class="ic-title-wrap"><span class="item-name" style="${nameStyle}">${escHtml(title)}</span><div class="ic-badges">${qty}${mutTags}</div></div></div>
  <div class="ic-meta">${rarity?`<span class="badge ${rc}">${escHtml(rarity)}</span>`:''}</div>
</div>`;
    }).join('')}</div>`;
  }
  function wireFishImageErrors(root) {
    if (!root) return;
    root.querySelectorAll('.item-card img[data-item-id]:not([data-placeholder])').forEach((img) => {
      const card = img.closest('.item-card');
      const itemId = img.getAttribute('data-item-id');
      const item = { itemId, imageAssetId: img.getAttribute('data-asset-id'), name: card && card.querySelector('.item-name') && card.querySelector('.item-name').textContent };
      img.onerror = () => onFishImageError(img, item);
    });
  }

  function createCard(username) {
    const el = document.createElement('div');
    el.className = 'tracker-card expanded';
    el.dataset.user = username.toLowerCase();
    el.innerHTML = `
<div class="card-head">
  <span class="dot" aria-hidden="true"></span>
  <span class="card-username">${escHtml(username)}</span>
  <div class="card-meta-row">
    <span class="pill" data-fish-count>Fish: <strong>-</strong></span>
    <span class="pill" data-sync-time></span>
  </div>
  <button class="btn-remove" data-remove-btn aria-label="Remove">x Remove</button>
  <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><polyline points="18 15 12 9 6 15"></polyline></svg>
</div>
<div class="card-status-line" data-status-line>&#x23F3; Waiting for <strong>${escHtml(username)}</strong> to execute the script in-game...</div>
<div data-global-db-proof></div>
<div class="card-body" data-card-body><div class="card-empty">&#x23F3; Awaiting first data...</div></div>`

    el.querySelector('.card-head').addEventListener('click', e => { if (!e.target.closest('[data-remove-btn]')) el.classList.toggle('expanded'); });
    el.querySelector('[data-remove-btn]').addEventListener('click', e => { e.stopPropagation(); removeTracker(username.toLowerCase()); });
    return el;
  }

  function updateCard(card, data) {
    card.classList.remove('state-waiting','state-error');
    card.classList.add('state-live');
    const c = card.querySelector('[data-fish-count]');
    const s = card.querySelector('[data-sync-time]');
    const l = card.querySelector('[data-status-line]');
    const b = card.querySelector('[data-card-body]');
    const fishList = getPublicFishItems(data);
    logFishOnlyRender(card.dataset.user, data, fishList);
    if (c) c.innerHTML = fishCountLabel(data, fishList);
    if (s) s.textContent = `Last sync: ${fmtTime(syncTimestamp(data))}`;
    if (l) l.innerHTML = `&#x1F7E2; Live &mdash; User ID: <strong>${data.userId||'-'}</strong>`;
    const gdb = card.querySelector('[data-global-db-proof]');
    if (gdb) gdb.innerHTML = buildGlobalDbProofHtml(data);
    if (b) patchItemsGrid(b, fishList);
  }

  function setCardWaiting(card, name) {
    card.classList.remove('state-live','state-error');
    card.classList.add('state-waiting');
    const l = card.querySelector('[data-status-line]');
    const s = card.querySelector('[data-sync-time]');
    if (l) l.innerHTML = `&#x23F3; Waiting for <strong>${escHtml(name)}</strong> to execute the script in-game...`;
    if (s) s.textContent = '';
  }

  // Map a tracker_status discovery phase to a human-readable message.
  function phaseMessage(phase) {
    switch (phase) {
      case 'replion_client_found':
        return 'Replion client found, locating player data...';
      case 'player_data_not_found':
        return 'Replion client found, player data not found yet.';
      case 'inventory_path_missing':
        return 'Replion data found, inventory path not matched. Send logs.';
      case 'inventory_empty':
        return 'Replion inventory found, but it is empty.';
      case 'inventory_parse_failed':
        return 'Replion inventory found, parser needs update. Send logs.';
      case 'replion_missing':
        return 'Replion library not found in this game.';
      case 'player_data_selected':
        return 'Player data found — reading inventory...';
      case 'startup':
      case 'live':
      default:
        return 'Script running — locating Replion data...';
    }
  }

  // Script is executing (tracker_status online) but no inventory snapshot yet.
  // Green dot + phase message instead of "Awaiting first data".
  function setCardRunning(card, name, data) {
    card.classList.remove('state-waiting','state-error');
    card.classList.add('state-live');
    const l = card.querySelector('[data-status-line]');
    const s = card.querySelector('[data-sync-time]');
    const c = card.querySelector('[data-fish-count]');
    const b = card.querySelector('[data-card-body]');
    if (l) l.innerHTML = `&#x1F7E2; ${escHtml(phaseMessage(data.phase))}`;
    if (s) s.textContent = syncTimestamp(data) ? `Sync: ${fmtTime(syncTimestamp(data))}` : '';
    if (c) c.innerHTML = `Fish: <strong>-</strong>`;
    let bodyHtml = `<div class="card-empty">&#x1F7E2; ${escHtml(phaseMessage(data.phase))}</div>`;
    // Show parse stats whenever raw>0 accepted=0, regardless of phase label.
    const ps = data.parseStats;
    const showParseDebug = ps && ps.raw > 0
      && (ps.acceptedInstances === 0 || ps.acceptedInstances === undefined)
      && (ps.accepted === 0 || ps.accepted === undefined)
      && (data.phase === 'inventory_parse_failed' || data.phase === 'inventory_empty');
    if (showParseDebug) {
      bodyHtml += `<div class="card-empty" style="font-size:0.8em;color:#8a94a6;margin-top:4px">`
        + `Raw: ${ps.raw ?? '?'} &middot; Accepted: ${ps.accepted ?? 0} &middot; Instances: ${ps.acceptedInstances ?? 0} &middot; Rejected: ${ps.rejected ?? '?'}`
        + (ps.selectedPath ? ` &middot; Path: ${escHtml(ps.selectedPath)}` : '')
        + (data.trackerBuild ? ` &middot; Build: ${escHtml(data.trackerBuild)}` : '')
        + `</div>`;
    } else if (data.trackerBuild || (ps && ps.acceptedInstances > 0)) {
      bodyHtml += `<div class="card-empty" style="font-size:0.75em;color:#6b7280;margin-top:4px">`
        + (data.trackerBuild ? `Build: ${escHtml(data.trackerBuild)}` : '')
        + (ps && ps.acceptedInstances > 0 ? ` &middot; Instances: ${ps.acceptedInstances} &middot; Unique: ${ps.accepted ?? 0}` : '')
        + `</div>`;
    }
    if (b) b.innerHTML = bodyHtml;
  }

  function setCardOffline(card, name, lastData) {
    card.classList.remove('state-live','state-waiting');
    card.classList.add('state-error');
    const l = card.querySelector('[data-status-line]');
    const s = card.querySelector('[data-sync-time]');
    const c = card.querySelector('[data-fish-count]');
    const b = card.querySelector('[data-card-body]');
    if (l) l.innerHTML = `&#x1F534; Offline &mdash; <strong>${escHtml(name)}</strong> is not running the tracker`;
    if (s && lastData) s.textContent = `Last sync: ${fmtTime(syncTimestamp(lastData))}`;
    if (lastData) {
      const fishList = getPublicFishItems(lastData);
      if (c) c.innerHTML = fishCountLabel(lastData, fishList).replace('</span>', ' &mdash; Offline</span>');
      if (b) patchItemsGrid(b, fishList);
    }
  }

  function setCardError(card) {
    card.classList.remove('state-live','state-waiting');
    card.classList.add('state-error');
    const l = card.querySelector('[data-status-line]');
    if (l) l.textContent = 'Network error - retrying...';
  }

  async function pollUser(key) {
    const entry = trackers.get(key);
    if (!entry) return;
    try {
      const res = await fetch(`/api/fishit-tracker/get-backpack/${encodeURIComponent(key)}`);
      if (!trackers.has(key)) return;
      if (res.status === 404) {
        if (entry.lastData) {
          setCardOffline(entry.el, entry.displayName, entry.lastData);
        } else {
          setCardWaiting(entry.el, entry.displayName);
        }
        return;
      }
      if (!res.ok) { setCardError(entry.el); return; }
      const data = await res.json();
      entry.lastData = data;
      const fishList = getPublicFishItems(data);
      const hasFish = fishList.length > 0;
      if (data.isOnline === false) {
        // Offline: keep the last known inventory visible with a red dot.
        setCardOffline(entry.el, entry.displayName, data);
      } else if (hasFish) {
        // Online with a real inventory snapshot.
        updateCard(entry.el, data);
      } else {
        // Online (tracker_status heartbeat) but no inventory yet: show the
        // running phase with a green dot, never "Awaiting first data".
        setCardRunning(entry.el, entry.displayName, data);
      }
    } catch { if (trackers.has(key)) setCardError(entry.el); }
  }

  function addTracker(username) {
    const raw = username.trim();
    const key = raw.toLowerCase();
    if (!key || !/^[a-z0-9_]{3,20}$/.test(key)) return;
    if (trackers.has(key)) {
      const e = trackers.get(key);
      e.el.scrollIntoView({ behavior:'smooth', block:'center' });
      return;
    }
    const card  = createCard(raw);
    trackerListEl.appendChild(card);
    const timer = setInterval(() => pollUser(key), POLL_MS);
    trackers.set(key, { timer, el: card, displayName: raw, lastData: null });
    pollUser(key);
    updateSummary();
    saveCurrent();
  }

  function removeTracker(key) {
    const entry = trackers.get(key);
    if (!entry) return;
    clearInterval(entry.timer);
    entry.el.remove();
    trackers.delete(key);
    updateSummary();
    saveCurrent();
  }

  copyBtn.addEventListener('click', () => {
    const code = document.getElementById('loadstringCode').textContent;
    navigator.clipboard.writeText(code).then(() => {
      copyBtn.textContent = '? Copied!';
      copyBtn.classList.add('copied');
      setTimeout(() => { copyBtn.textContent = 'Copy'; copyBtn.classList.remove('copied'); }, 2000);
    });
  });

  addBtn.addEventListener('click', () => { const v=inputEl.value.trim(); if(v){addTracker(v);inputEl.value='';} inputEl.focus(); });
  inputEl.addEventListener('keydown', e => { if(e.key==='Enter'){const v=inputEl.value.trim();if(v){addTracker(v);inputEl.value='';}} });

  // Restore saved sessions
  loadSaved().forEach(u => addTracker(u));
  updateSummary();
}());
</script>
</body>
</html>
