<!DOCTYPE html>
<html lang="en" data-theme="dark" data-render-build="<%= typeof renderBuild !== 'undefined' ? renderBuild : 'BLOCKER10Z7_METADATA_SPECIES_EXTRACTION_2026_06_08' %>" data-public-api-build="<%= typeof publicApiBuild !== 'undefined' ? publicApiBuild : 'BLOCKER10Z7_METADATA_SPECIES_EXTRACTION_2026_06_08' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>&#x1F3A3; Fish It Live Inventory Tracker</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0f14;
      --surface:   #161a22;
      --surface2:  #1e2430;
      --border:    #2a3040;
      --accent:    #3b82f6;
      --accent2:   #60a5fa;
      --text:      #e2e8f0;
      --muted:     #8a94a6;
      --danger:    #ef4444;
      --success:   #22c55e;
      --warn:      #f59e0b;
      --shine:     #fbbf24;
      --radius:    10px;
      --radius-lg: 16px;
      --font:      'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    html, body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 15px;
      line-height: 1.5;
    }

    .page { min-height:100vh; display:flex; flex-direction:column; align-items:center; padding:32px 16px 64px; }
    .inner { width:100%; max-width:1040px; }

    .back-link { display:inline-flex; align-items:center; gap:6px; color:var(--muted); text-decoration:none; font-size:.85rem; margin-bottom:24px; transition:color .15s; }
    .back-link:hover { color:var(--accent2); }

    .header { text-align:center; margin-bottom:28px; }
    .header h1 { font-size:clamp(1.5rem,4vw,2.2rem); font-weight:700; background:linear-gradient(135deg,#3b82f6,#60a5fa,#93c5fd); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; letter-spacing:-.5px; margin-bottom:6px; }
    .header p { color:var(--muted); font-size:.9rem; }

    .add-row { display:flex; gap:10px; margin-bottom:20px; }
    .add-row input { flex:1; padding:12px 16px; background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius); color:var(--text); font-size:.95rem; font-family:var(--font); outline:none; transition:border-color .15s; }
    .add-row input:focus { border-color:var(--accent); }
    .add-row input::placeholder { color:var(--muted); }

    .btn { padding:12px 22px; border-radius:var(--radius); border:none; cursor:pointer; font-size:.9rem; font-weight:600; font-family:var(--font); transition:opacity .15s,transform .1s; white-space:nowrap; }
    .btn:active { transform:scale(.97); }
    .btn-primary { background:linear-gradient(135deg,#3b82f6,#2563eb); color:#fff; }
    .btn-primary:hover { opacity:.9; }

    .summary-bar { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; font-size:.85rem; color:var(--muted); }
    .summary-bar strong { color:var(--text); }

    .no-trackers { text-align:center; padding:60px 20px; color:var(--muted); border:1.5px dashed var(--border); border-radius:var(--radius-lg); margin-bottom:24px; }
    .no-trackers .icon { font-size:2.5rem; margin-bottom:10px; }
    .no-trackers p { font-size:.9rem; }

    .tracker-card { background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius-lg); margin-bottom:14px; overflow:hidden; animation:slideIn .2s ease; transition:border-color .25s; }
    .tracker-card.state-live    { border-color:var(--success); }
    .tracker-card.state-waiting { border-color:var(--warn); }
    .tracker-card.state-error   { border-color:var(--danger); }

    @keyframes slideIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

    .card-head { display:flex; align-items:center; gap:12px; padding:14px 16px; cursor:pointer; user-select:none; }
    .card-head:hover { background:var(--surface2); }

    .dot { width:9px; height:9px; border-radius:50%; flex-shrink:0; background:var(--muted); transition:background .2s; }
    .state-live    .dot { background:var(--success); animation:pulse 1.4s ease-in-out infinite; }
    .state-waiting .dot { background:var(--warn);    animation:pulse 1.4s ease-in-out infinite; }
    .state-error   .dot { background:var(--danger); }

    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }

    .card-username { font-weight:700; font-size:1rem; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .card-meta-row { display:flex; align-items:center; gap:10px; font-size:.8rem; color:var(--muted); flex-shrink:0; }

    .pill { padding:3px 10px; border-radius:99px; background:var(--surface2); border:1px solid var(--border); font-size:.78rem; color:var(--muted); white-space:nowrap; }
    .pill strong { color:var(--text); }

    .chevron { width:16px; height:16px; color:var(--muted); transition:transform .2s; flex-shrink:0; }
    .tracker-card.expanded .chevron { transform:rotate(180deg); }

    .btn-remove { background:none; border:1px solid var(--border); border-radius:var(--radius); color:var(--muted); cursor:pointer; padding:4px 10px; font-size:.78rem; font-family:var(--font); transition:color .15s,border-color .15s,background .15s; flex-shrink:0; }
    .btn-remove:hover { color:var(--danger); border-color:var(--danger); background:#1a0808; }

    .card-status-line { padding:0 16px 10px; font-size:.8rem; color:var(--muted); }

    .card-body { padding:0 16px 16px; display:none; }
    .tracker-card.expanded .card-body { display:block; }

    .items-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:12px; margin-top:4px; }

    .item-card, .fish-card {
      --card-fg:#fff;
      --card-muted-fg:rgba(255,255,255,.88);
      --badge-bg:rgba(0,0,0,.42);
      --badge-fg:#fff;
      --image-glow:rgba(255,255,255,.1);
      border:1px solid rgba(255,255,255,.08);
      border-radius:14px;
      padding:12px 14px;
      min-height:0;
      display:grid;
      grid-template-columns:auto 1fr;
      grid-template-areas:"image body";
      gap:10px 12px;
      align-items:start;
      color:var(--card-fg);
      box-shadow:0 10px 24px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.06);
      overflow:hidden;
      transition:transform .15s,box-shadow .2s;
      animation:fadeIn .2s ease;
      position:relative;
    }
    .item-card:hover, .fish-card:hover { transform:translateY(-2px); box-shadow:0 14px 28px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.08); }
    .item-card.rarity-common, .fish-card.rarity-common { --card-fg:#e2e8f0; --card-muted-fg:#8a94a6; --badge-bg:rgba(0,0,0,.35); --image-glow:rgba(148,163,184,.12); background:linear-gradient(135deg,#242936 0%,#141820 100%); }
    .item-card.rarity-uncommon, .fish-card.rarity-uncommon { --card-fg:#e2e8f0; --card-muted-fg:rgba(255,255,255,.85); --badge-bg:rgba(0,0,0,.38); --image-glow:rgba(74,222,128,.14); background:linear-gradient(135deg,#2a3440 0%,#1a2030 100%); }
    .item-card.rarity-rare, .fish-card.rarity-rare { --card-fg:#fff; --card-muted-fg:#fff; --badge-bg:rgba(0,0,0,.52); --image-glow:rgba(96,180,255,.28); background:linear-gradient(135deg,#60b4ff 0%,#3d88dc 100%); }
    .item-card.rarity-epic, .fish-card.rarity-epic { --card-fg:#fff; --card-muted-fg:#fff; --badge-bg:rgba(0,0,0,.5); --image-glow:rgba(255,37,37,.22); background:linear-gradient(135deg,#ff2525 0%,#c90d12 100%); }
    .item-card.rarity-legendary, .fish-card.rarity-legendary { --card-fg:#fff; --card-muted-fg:#fff; --badge-bg:rgba(0,0,0,.5); --image-glow:rgba(255,201,54,.24); background:linear-gradient(135deg,#ffc936 0%,#d79413 100%); }
    .item-card.rarity-mythic, .fish-card.rarity-mythic { --card-fg:#fff; --card-muted-fg:#fff; --badge-bg:rgba(0,0,0,.48); --image-glow:rgba(184,121,255,.24); background:linear-gradient(135deg,#b879ff 0%,#8152d6 100%); }
    .item-card.rarity-secret, .fish-card.rarity-secret { --card-fg:#fff; --card-muted-fg:#fff; --badge-bg:rgba(0,0,0,.52); --image-glow:rgba(16,228,135,.28); background:linear-gradient(135deg,#10e487 0%,#09c96f 55%,#079b59 100%); }
    .item-card.rarity-forgotten, .fish-card.rarity-forgotten { --card-fg:#fff; --card-muted-fg:rgba(255,255,255,.92); --badge-bg:rgba(0,0,0,.58); --image-glow:rgba(255,255,255,.16); background:linear-gradient(135deg,#f0f0f0 0%,#777 50%,#111 100%); }

    .stones-section { margin-top: 14px; padding-top: 10px; border-top: 1px solid var(--border); }
    .stones-section__title { font-size: 0.82rem; color: var(--muted); margin-bottom: 8px; font-weight: 600; letter-spacing: 0.02em; }
    .stone-card { background: linear-gradient(135deg, #252b3a 0%, #171c28 100%); }
    .stone-card__icon { display: flex; align-items: center; justify-content: center; font-size: 1.55rem; min-height: 56px; }
    .item-card:not([class*="rarity-"]), .fish-card:not([class*="rarity-"]) { --card-fg:#e2e8f0; --card-muted-fg:#8a94a6; --badge-bg:rgba(0,0,0,.35); --image-glow:rgba(148,163,184,.1); background:linear-gradient(135deg,#242936 0%,#141820 100%); border:1px solid var(--border); }

    .fish-card__imageWrap {
      grid-area:image;
      width:clamp(64px, 20vw, 88px);
      height:clamp(64px, 20vw, 88px);
      min-width:64px;
      min-height:64px;
      display:flex;
      align-items:center;
      justify-content:center;
      border-radius:12px;
      background:rgba(0,0,0,.28);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.08), 0 4px 18px var(--image-glow);
      flex-shrink:0;
    }
    .fish-card__image, .fish-card__imageWrap img {
      width:100%;
      height:100%;
      max-width:88px;
      max-height:88px;
      object-fit:contain;
      border-radius:8px;
      filter:drop-shadow(0 2px 8px rgba(0,0,0,.35));
      background:transparent!important;
    }
    .fish-card__imageWrap img[data-placeholder="true"] {
      opacity:.55;
      filter:none;
    }
    .fish-card__body {
      grid-area:body;
      display:flex;
      flex-direction:column;
      gap:8px;
      min-width:0;
      justify-content:center;
    }
    .fish-card__name, .item-card .item-name, .fish-card .item-name {
      color:var(--card-fg)!important;
      font-weight:650;
      font-size:clamp(.84rem, 2.4vw, .96rem);
      line-height:1.22;
      min-width:0;
      word-break:normal;
      overflow-wrap:break-word;
      white-space:normal;
      display:-webkit-box;
      -webkit-line-clamp:2;
      -webkit-box-orient:vertical;
      overflow:hidden;
      text-shadow:0 1px 3px rgba(0,0,0,.5), 0 0 1px rgba(0,0,0,.35);
    }
    .fish-card__amountRow {
      display:flex;
      align-items:center;
      margin-top:2px;
    }
    .fish-card__amount, .ic-qty.fish-card__amount {
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:44px;
      min-height:34px;
      padding:0 14px;
      border-radius:10px;
      background:rgba(0,0,0,.68)!important;
      border:1px solid rgba(255,255,255,.34)!important;
      color:#fff!important;
      font-size:clamp(1rem, 2.8vw, 1.12rem);
      font-weight:800;
      line-height:1;
      letter-spacing:.02em;
      white-space:nowrap;
      text-shadow:0 1px 3px rgba(0,0,0,.55);
      box-shadow:0 4px 14px rgba(0,0,0,.35), inset 0 1px 0 rgba(255,255,255,.12);
      box-sizing:border-box;
    }

    /* Legacy hooks kept for patch/update paths */
    .ic-head { display:contents; }
    .ic-title-wrap { display:contents; }
    .ic-badges { display:contents; }
    .global-db-proof { margin-top:8px; border:1px solid var(--border); border-radius:var(--radius); background:var(--surface2); }
    .global-db-proof summary { cursor:pointer; padding:8px 10px; font-size:.78rem; color:#93c5fd; user-select:none; }
    .global-db-proof .gdb-body { padding:8px 10px 10px; font-size:.74rem; color:var(--muted); line-height:1.45; }
    .global-db-proof .gdb-row { display:flex; justify-content:space-between; gap:8px; }
    .global-db-proof .gdb-on { color:#4ade80; font-weight:600; }
    .global-db-debug { margin-top:6px; font-size:.68rem; color:#8a94a6; max-height:120px; overflow:auto; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(5px)} to{opacity:1;transform:translateY(0)} }

    .badge { font-size:.72rem; padding:2px 9px; border-radius:99px; border:1px solid var(--border); background:var(--surface); color:var(--muted); }
    .badge-weight  { color:var(--accent2); border-color:#1d3a5c; background:#0d1f30; }
    .rarity-common    { color:var(--muted); }
    .rarity-uncommon  { color:#4ade80;  border-color:#143d20; background:#091a0f; }
    .rarity-rare      { color:#60a5fa;  border-color:#1d3a5c; background:#0d1f30; }
    .rarity-epic      { color:#c084fc;  border-color:#3d1f5e; background:#1a0f2e; }
    .rarity-legendary { color:var(--shine); border-color:#7a5a00; background:#3d2c00; }
    .rarity-secret, .badge-rarity-secret { color:#22d3ee; border-color:#0e7490; background:#042f2e; }
    .rarity-forgotten { color:#818cf8;  border-color:#1e1e5c; background:#0d0d30; }

    .card-empty { text-align:center; padding:24px; color:var(--muted); font-size:.85rem; }

    .loadstring-box { margin-top:36px; background:var(--surface); border:1.5px solid var(--border); border-radius:var(--radius-lg); padding:20px; }
    .loadstring-box h3 { font-size:.8rem; color:var(--muted); text-transform:uppercase; letter-spacing:.06em; margin-bottom:12px; }
    .code-row { display:flex; gap:8px; align-items:stretch; }
    .code-block { flex:1; font-family:'Consolas','Fira Code',monospace; font-size:.82rem; background:#0a0c10; border:1px solid var(--border); border-radius:var(--radius); padding:12px 14px; color:#93c5fd; overflow-x:auto; white-space:nowrap; }
    .btn-copy { padding:0 16px; background:var(--surface2); border:1.5px solid var(--border); border-radius:var(--radius); color:var(--text); cursor:pointer; font-size:.85rem; font-family:var(--font); font-weight:600; white-space:nowrap; transition:background .15s,border-color .15s,color .15s; }
    .btn-copy:hover  { background:var(--accent); border-color:var(--accent); color:#fff; }
    .btn-copy.copied { background:var(--success); border-color:var(--success); color:#fff; }

    @media (max-width:560px) {
      .add-row { flex-wrap:wrap; }
      .btn { width:100%; }
      .code-row { flex-direction:column; }
      .btn-copy { padding:10px; }
      .card-meta-row { gap:6px; }
      .items-grid { grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:10px; }
      .fish-card__imageWrap { width:clamp(56px, 18vw, 72px); height:clamp(56px, 18vw, 72px); min-width:56px; min-height:56px; }
    }
    @media (min-width:900px) {
      .items-grid { grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); }
    }
  </style>
</head>
<body data-ui-marker="BLOCKER10Z15_AMOUNT_MOVED_TO_MIDDLE_SECTION_2026_06_08">
<!-- BLOCKER10Z15_AMOUNT_MOVED_TO_MIDDLE_SECTION_2026_06_08 -->
<div class="page">
  <div class="inner">

    <a href="/" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      Back to DENG Tool
    </a>

    <header class="header">
      <h1>&#x1F3A3; Fish It Live Inventory Tracker</h1>
      <p>Track unlimited players simultaneously � sessions are saved and restored on page reload.</p>
    </header>

    <div class="add-row">
      <input type="text" id="usernameInput" placeholder="Enter Roblox Username..." maxlength="20" autocomplete="off" spellcheck="false" aria-label="Roblox username">
      <button class="btn btn-primary" id="addBtn" type="button">+ Add Tracker</button>
    </div>

    <div class="summary-bar">
      <span id="summaryText">No active trackers</span>
    </div>

    <div id="trackerList"></div>

    <div class="no-trackers" id="noTrackersMsg">
      <div class="icon">&#x1F3A3;</div>
      <p>Add a Roblox username above to start live tracking.<br>Sessions are saved automatically and restored on page reload.</p>
    </div>

    <div class="loadstring-box">
      <h3>Executor Script � copy &amp; run in-game</h3>
      <div class="code-row">
        <div class="code-block" id="loadstringCode">loadstring(game:HttpGet("https://raw.githubusercontent.com/dengjiangbin/deng-tool-rejoin/main/tracker.lua?t=" .. tostring(os.time())))()</div>
        <button class="btn-copy" id="copyBtn" type="button">Copy</button>
      </div>
    </div>

  </div>
</div>
<script>
(function () {
  'use strict';

  const LS_KEY        = 'fishit_tracked_users';
  const POLL_MS       = 5000;
  const DEBUG_GLOBAL  = /(?:^|[?&])debug=global(?:&|$)/.test(window.location.search);
  const RENDER_BUILD  = document.documentElement.getAttribute('data-render-build')
    || 'BLOCKER10Z7_METADATA_SPECIES_EXTRACTION_2026_06_08';
  const PUBLIC_API_BUILD = document.documentElement.getAttribute('data-public-api-build')
    || 'BLOCKER10Z7_METADATA_SPECIES_EXTRACTION_2026_06_08';
  const RARITY_NAME_COLORS = {
    common:'#9ca3af', uncommon:'#4ade80', rare:'#60a5fa', epic:'#c084fc',
    legendary:'#eab308', legend:'#eab308', mythic:'#f472b6', secret:'#22d3ee', forgotten:'#818cf8',
  };
  const RARITY_MAP = { common:'rarity-common', uncommon:'rarity-uncommon', rare:'rarity-rare', epic:'rarity-epic', legendary:'rarity-legendary', legend:'rarity-legendary', mythic:'rarity-mythic', secret:'rarity-secret badge-rarity-secret', forgotten:'rarity-forgotten' };
  const CARD_RARITY_MAP = { common:'rarity-common', uncommon:'rarity-uncommon', rare:'rarity-rare', epic:'rarity-epic', legendary:'rarity-legendary', legend:'rarity-legendary', mythic:'rarity-mythic', secret:'rarity-secret', forgotten:'rarity-forgotten' };

  const trackers       = new Map();
  const inputEl        = document.getElementById('usernameInput');
  const addBtn         = document.getElementById('addBtn');
  const trackerListEl  = document.getElementById('trackerList');
  const noTrackersMsg  = document.getElementById('noTrackersMsg');
  const summaryTextEl  = document.getElementById('summaryText');
  const copyBtn        = document.getElementById('copyBtn');

  function loadSaved() { try { return JSON.parse(localStorage.getItem(LS_KEY) || '[]'); } catch { return []; } }
  function saveCurrent() { try { localStorage.setItem(LS_KEY, JSON.stringify([...trackers.keys()])); } catch {} }

  function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function fmtTime(iso) {
    if (!iso) return '-';
    try {
      return new Date(iso).toLocaleTimeString('en-GB', {
        timeZone: 'Asia/Jakarta', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
      }) + ' WIB';
    } catch { return '-'; }
  }
  function syncTimestamp(data) {
    return data && (data.lastInventoryAt || data.lastSeenAt || data.updatedAt) || null;
  }
  /** Public fish-only list (BLOCKER10K1). Never reads mixed enrichedItems or full inventory groups. */
  function getPublicFishItems(data) {
    if (!data) return [];
    if (Array.isArray(data.fishItems)) return data.fishItems;
    if (Array.isArray(data.publicItems)) return data.publicItems;
    if (data.fishInventory && Array.isArray(data.fishInventory.fish)) return data.fishInventory.fish;
    if (data.renderBuild === RENDER_BUILD && Array.isArray(data.items)) {
      return data.items.filter((it) => String(it.category || '').toLowerCase() === 'fish');
    }
    return [];
  }
  function getPublicStoneItems(data) {
    if (!data) return [];
    if (Array.isArray(data.stoneItems)) return data.stoneItems;
    if (Array.isArray(data.stoneInventory)) return data.stoneInventory;
    return [];
  }
  function stoneCardKey(item) {
    return `stone|${String(item.stoneType || item.itemId || item.name || 'unknown').toLowerCase()}`;
  }
  function buildStoneCardInnerHtml(item) {
    const amount = Number(item.amount || item.quantity || 1);
    const title = item.displayName || item.name || 'Enchant Stone';
    return `
  <div class="fish-card__imageWrap ic-head stone-card__icon">&#x1F48E;</div>
  <div class="fish-card__body ic-title-wrap">
    <span class="fish-card__name item-name stone-card__name" title="${escHtml(title)}">${escHtml(title)}</span>
    <div class="fish-card__amountRow ic-meta"><span class="fish-card__amount ic-qty">x${Number.isFinite(amount) ? amount : 1}</span></div>
  </div>`;
  }
  function buildStoneCardElement(item) {
    const card = document.createElement('div');
    card.className = 'item-card fish-card stone-card';
    card.setAttribute('data-card-key', stoneCardKey(item));
    card.setAttribute('data-kind', 'stone');
    card.innerHTML = buildStoneCardInnerHtml(item);
    return card;
  }
  function patchStonesGrid(container, items) {
    if (!container) return;
    if (!items || items.length === 0) {
      container.innerHTML = '';
      container.style.display = 'none';
      return;
    }
    container.style.display = '';
    let title = container.querySelector('.stones-section__title');
    if (!title) {
      container.innerHTML = '<div class="stones-section__title">Enchant Stones</div><div class="items-grid stones-grid"></div>';
      title = container.querySelector('.stones-section__title');
    }
    let grid = container.querySelector('.stones-grid');
    if (!grid) {
      grid = document.createElement('div');
      grid.className = 'items-grid stones-grid';
      container.appendChild(grid);
    }
    const nextKeys = new Set();
    const existing = new Map();
    grid.querySelectorAll('.stone-card[data-card-key]').forEach((el) => {
