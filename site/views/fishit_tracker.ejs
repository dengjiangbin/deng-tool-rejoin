    <div class="loadstring-box<%= (typeof apkEmbed !== 'undefined' && apkEmbed) ? ' is-compact' : '' %>">
      <h3>
        <span class="loadstring-box__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
        </span>
        <span>Executor Script &mdash; copy &amp; run in-game</span>
      </h3>
      <div class="code-row">
        <textarea class="code-block code-block--script" id="loadstringCode" readonly rows="2" spellcheck="false" aria-label="Tracker executor script"><%- typeof trackerLoadstring !== 'undefined' ? trackerLoadstring : '' %></textarea>
