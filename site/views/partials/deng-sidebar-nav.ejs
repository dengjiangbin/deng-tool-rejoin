<% const page = typeof activePage !== 'undefined' ? activePage : (typeof locals !== 'undefined' && locals.activePage) || ''; %>
<% const trackerMode = typeof sidebarNavMode !== 'undefined' && sidebarNavMode === 'tracker'; %>
<div class="sidebar-body sidebar-body--desktop">
  <div class="sidebar-section">
    <p class="sidebar-section-label">MAIN</p>
    <ul class="sidebar-menu">
      <li>
        <% if (trackerMode) { %>
        <button type="button" class="sidebar-link" data-inventory-section="dashboard">
        <% } else { %>
        <a href="/dashboard" class="sidebar-link <%= page === 'dashboard' ? 'is-active' : '' %>">
        <% } %>
          <span class="sidebar-link__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <rect x="3" y="3" width="7" height="8" rx="2"></rect>
              <rect x="14" y="3" width="7" height="5" rx="2"></rect>
              <rect x="14" y="12" width="7" height="9" rx="2"></rect>
              <rect x="3" y="15" width="7" height="6" rx="2"></rect>
            </svg>
          </span>
          <span class="sidebar-link__label">Dashboard</span>
        <% if (trackerMode) { %>
        </button>
        <% } else { %>
        </a>
        <% } %>
      </li>
      <li>
        <% if (trackerMode) { %>
        <button type="button" class="sidebar-link is-active" data-inventory-section="accounts">
        <% } else { %>
        <a href="/tracker" class="sidebar-link <%= page === 'tracker' ? 'is-active' : '' %>">
        <% } %>
          <span class="sidebar-link__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
            </svg>
          </span>
          <span class="sidebar-link__label">Live Tracker</span>
        <% if (trackerMode) { %>
        </button>
        <% } else { %>
        </a>
        <% } %>
      </li>
    </ul>
  </div>

  <%# Fish It has been merged into the /tracker Dashboard and removed as a
      standalone page. On /tracker the sidebar is intentionally focused on
      Dashboard + Live Tracker only, so the TOOLS section is hidden there. %>
  <% if (!trackerMode) { %>
  <div class="sidebar-section">
    <p class="sidebar-section-label">TOOLS</p>
    <ul class="sidebar-menu">
      <li>
        <a href="/license" class="sidebar-link <%= page === 'license' ? 'is-active' : '' %>">
          <span class="sidebar-link__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <circle cx="7.5" cy="14.5" r="3.5"></circle>
              <path d="M10.8 12.2 21 2"></path>
              <path d="m16 7 2 2"></path>
              <path d="m13.5 9.5 2 2"></path>
            </svg>
          </span>
          <span class="sidebar-link__label">My License</span>
        </a>
      </li>
      <li>
        <a href="/download" class="sidebar-link <%= page === 'download' ? 'is-active' : '' %>">
          <span class="sidebar-link__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 3v12"></path>
              <path d="m7 10 5 5 5-5"></path>
              <path d="M5 21h14"></path>
            </svg>
          </span>
          <span class="sidebar-link__label">Download</span>
        </a>
      </li>
    </ul>
  </div>
  <% } %>
</div>
