<% locals.activePage = 'license' %>

<div class="unlock-page" data-portal-step="provider-unlock" data-provider="<%= provider %>">
  <section class="unlock-card">
    <p class="eyebrow">Unlock Step 2</p>
    <h1 class="unlock-title"><%= provider === 'linkvertise' ? 'Linkvertise' : 'LootLabs' %> Unlock</h1>
    <p class="unlock-desc">
      Complete the provider page. After completion, the provider sends you back to the protected unlock URL and the backend generates your key.
    </p>

    <div class="unlock-url-box">
      <span class="mini-label">Protected unlock URL</span>
      <code><%= unlockUrl.replace(/\?.*/, '?challenge=...') %></code>
    </div>

    <a id="ad-unlock-link" href="<%= adUrl %>" class="btn btn-primary btn-block btn-lv">
      Continue to <%= provider === 'linkvertise' ? 'Linkvertise' : 'LootLabs' %>
    </a>

    <% if (provider === 'linkvertise') { %>
      <script src="https://publisher.linkvertise.com/cdn/linkvertise.js"></script>
      <script>
        window.addEventListener('DOMContentLoaded', function () {
          if (typeof linkvertise === 'function') {
            linkvertise(<%= publisherId %>, {
              whitelist: ['tool.deng.my.id/unlock/linkvertise'],
              blacklist: [
                'tool.deng.my.id/login',
                'tool.deng.my.id/dashboard',
                'tool.deng.my.id/license',
                'tool.deng.my.id/key/result',
                'tool.deng.my.id/health',
                'tool.deng.my.id/assets',
                'tool.deng.my.id/public'
              ]
            });
          }
        });
      </script>
    <% } %>

    <p class="unlock-note">
      The final key is not embedded in this page, localStorage, cookies, or the unlock URL.
    </p>
    <a href="/license" class="back-link">Cancel and go back</a>
  </section>
</div>
