<% locals.activePage = 'license' %>

<div class="page-header">
  <div>
    <p class="eyebrow">Unlock Step 1</p>
    <h1 class="page-title">Choose Provider</h1>
    <p class="page-subtitle">Pick one ad provider. After the ad step, you will return here to receive your key.</p>
  </div>
</div>

<%
  var PROVIDER_META = {
    lootlabs: {
      label: 'LootLabs',
      logo: '/images/providers/lootlabs.png',
      alt: 'LootLabs Logo',
    },
    linkvertise: {
      label: 'Linkvertise',
      logo: '/images/providers/linkvertise.png',
      alt: 'Linkvertise Logo',
    },
  };
  var lootlabsEnabled = providers.some(function(p){ return p.provider === 'lootlabs'; });
  var linkvertiseEnabled = providers.some(function(p){ return p.provider === 'linkvertise'; });
%>

<div class="provider-grid" data-portal-step="provider-choice">
  <% if (lootlabsEnabled) { %>
  <section class="provider-card">
    <div class="provider-mark provider-logo-wrap">
      <img class="provider-logo" src="<%= PROVIDER_META.lootlabs.logo %>" alt="<%= PROVIDER_META.lootlabs.alt %>" loading="lazy" decoding="async">
    </div>
    <h2 class="provider-name"><%= PROVIDER_META.lootlabs.label %></h2>
    <p class="provider-desc">Complete the LootLabs ad step, then return automatically to unlock your key.</p>
    <form method="POST" action="/key/provider/lootlabs">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="challenge_id" value="<%= challengeId %>">
      <input type="hidden" name="provider" value="lootlabs">
      <button type="submit" class="btn btn-primary btn-block btn-provider">Continue with LootLabs</button>
    </form>
  </section>
  <% } else { %>
  <section class="provider-card provider-card-disabled" aria-disabled="true">
    <div class="provider-mark provider-logo-wrap">
      <img class="provider-logo" src="<%= PROVIDER_META.lootlabs.logo %>" alt="<%= PROVIDER_META.lootlabs.alt %>" loading="lazy" decoding="async">
    </div>
    <h2 class="provider-name"><%= PROVIDER_META.lootlabs.label %></h2>
    <p class="alert alert-error" role="note" style="font-size:.9rem;margin:12px 0">
      LootLabs is temporarily unavailable.
    </p>
    <button class="btn btn-outline btn-block btn-provider" disabled aria-disabled="true">Unavailable</button>
  </section>
  <% } %>

  <% if (linkvertiseEnabled) { %>
  <section class="provider-card">
    <div class="provider-mark provider-logo-wrap">
      <img class="provider-logo" src="<%= PROVIDER_META.linkvertise.logo %>" alt="<%= PROVIDER_META.linkvertise.alt %>" loading="lazy" decoding="async">
    </div>
    <h2 class="provider-name"><%= PROVIDER_META.linkvertise.label %></h2>
    <p class="provider-desc">Complete the Linkvertise ad step, then return automatically to unlock your key.</p>
    <form method="POST" action="/key/provider/linkvertise">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="challenge_id" value="<%= challengeId %>">
      <input type="hidden" name="provider" value="linkvertise">
      <button type="submit" class="btn btn-primary btn-block btn-provider">Continue with Linkvertise</button>
    </form>
  </section>
  <% } else { %>
  <section class="provider-card provider-card-disabled" aria-disabled="true">
    <div class="provider-mark provider-logo-wrap">
      <img class="provider-logo" src="<%= PROVIDER_META.linkvertise.logo %>" alt="<%= PROVIDER_META.linkvertise.alt %>" loading="lazy" decoding="async">
    </div>
    <h2 class="provider-name"><%= PROVIDER_META.linkvertise.label %></h2>
    <p class="alert alert-error" role="note" style="font-size:.9rem;margin:12px 0">
      Linkvertise is temporarily unavailable.
    </p>
    <button class="btn btn-outline btn-block btn-provider" disabled aria-disabled="true">Unavailable</button>
  </section>
  <% } %>
</div>

<div class="back-link-wrap">
  <a href="/license" class="back-link">Cancel and return to My License</a>
</div>
