<% locals.activePage = 'license' %>

<div class="page-header">
  <div>
    <p class="eyebrow">Unlock Step 1</p>
    <h1 class="page-title">Choose Provider</h1>
    <p class="page-subtitle">Pick one ad provider. After the ad step, you will return here to receive your key.</p>
  </div>
</div>

<%
  var lootlabsEnabled = providers.some(function(p){ return p.provider === 'lootlabs'; });
  var linkvertiseEnabled = providers.some(function(p){ return p.provider === 'linkvertise'; });
%>

<div class="provider-grid" data-portal-step="provider-choice">
  <% if (lootlabsEnabled) { %>
  <section class="provider-card">
    <div class="provider-mark">LL</div>
    <h2 class="provider-name">LootLabs</h2>
    <p class="provider-desc">Complete the LootLabs unlock, then return through the protected completion route.</p>
    <form method="POST" action="/key/provider/lootlabs">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="challenge_id" value="<%= challengeId %>">
      <input type="hidden" name="provider" value="lootlabs">
      <button type="submit" class="btn btn-primary btn-block btn-provider">LootLabs</button>
    </form>
  </section>
  <% } else { %>
  <section class="provider-card provider-card-disabled" aria-disabled="true">
    <div class="provider-mark">LL</div>
    <h2 class="provider-name">LootLabs</h2>
    <p class="provider-desc">LootLabs is temporarily unavailable. Please check back later.</p>
    <button class="btn btn-outline btn-block btn-provider" disabled aria-disabled="true">Unavailable</button>
  </section>
  <% } %>

  <% if (linkvertiseEnabled) { %>
  <section class="provider-card">
    <div class="provider-mark">LV</div>
    <h2 class="provider-name">Linkvertise</h2>
    <p class="provider-desc">Complete the Linkvertise unlock, then return through the protected completion route.</p>
    <form method="POST" action="/key/provider/linkvertise">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="challenge_id" value="<%= challengeId %>">
      <input type="hidden" name="provider" value="linkvertise">
      <button type="submit" class="btn btn-outline btn-block btn-provider">Linkvertise</button>
    </form>
  </section>
  <% } else { %>
  <section class="provider-card provider-card-disabled" aria-disabled="true">
    <div class="provider-mark">LV</div>
    <h2 class="provider-name">Linkvertise</h2>
    <p class="alert alert-error" role="note" style="font-size:.9rem;margin:12px 0">
      Linkvertise is temporarily unavailable.<br>Please use LootLabs.
    </p>
    <button class="btn btn-outline btn-block btn-provider" disabled aria-disabled="true">Unavailable</button>
  </section>
  <% } %>
</div>

<div class="back-link-wrap">
  <a href="/license" class="back-link">Cancel and return to My License</a>
</div>
