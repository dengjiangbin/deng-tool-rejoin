<% locals.activePage = 'license' %>

<div class="page-header">
  <div>
    <p class="eyebrow">License Center</p>
    <h1 class="page-title">My License</h1>
    <p class="page-subtitle">Complete one ad step, then use the key inside DENG Tool Rejoin.</p>
  </div>
</div>

<section class="section-card generate-card" data-portal-step="license">
  <div class="generate-header">
    <div>
      <h2 class="section-title">Generate Rejoin Key</h2>
      <p class="section-desc">Complete one ad step, then use the key inside DENG Tool Rejoin.</p>
    </div>
  </div>

  <p class="section-desc license-expiry-hint">Each key works on one device and expires 48 hours after it is generated.</p>

  <%
    var flashError = flash && flash.error ? flash.error : '';
    var flashReason = flash && flash.blockReason ? flash.blockReason : '';
  %>
  <% if (flashError) { %>
    <div class="block-notice license-block-notice license-flash-error" data-server-license-notice data-block-reason="<%= flashReason || 'server_error' %>" role="status">
      <%= flashError %>
    </div>
  <% } else if (flash && flash.cooldown && flash.cooldown > 0) { %>
    <div class="cooldown-notice block-notice" data-server-license-notice data-block-reason="cooldown_active" data-seconds="<%= flash.cooldown %>" role="status">
      Cooldown active: <span class="countdown"></span>
    </div>
  <% } else if (!existingUnusedKey && cooldown && !cooldown.allowed && cooldown.secondsLeft > 0) { %>
    <div class="cooldown-notice block-notice" data-server-license-notice data-block-reason="cooldown_active" data-seconds="<%= cooldown.secondsLeft %>" role="status">
      Cooldown active: <span class="countdown"></span>
    </div>
  <% } %>

  <div class="eligibility-notice block-notice license-block-notice" data-eligibility-notice hidden></div>

  <% if (existingUnusedKey) { %>
    <div class="unused-key-recovery">
      <p class="empty-title">You already have an unused key.</p>
      <p class="empty-text">Copy this key before generating another one.</p>
      <div class="key-display-wrap">
        <code class="key-display" id="existing-key-value"><%= existingUnusedKey.key %></code>
        <button class="btn-copy" type="button" data-copy-key data-key="<%= existingUnusedKey.key %>" aria-label="Copy key">Copy</button>
      </div>
      <% if (existingUnusedKey.expires_at_formatted && existingUnusedKey.expires_at_formatted !== 'None') { %>
        <p class="empty-text">Expires: <%= existingUnusedKey.expires_at_formatted %></p>
      <% } %>
      <p class="empty-text">Each key works on one device and expires 48 hours after it is generated.</p>
    </div>
  <% } %>

  <div class="license-actions" data-license-actions data-csrf="<%= csrfToken %>" data-eligibility-refresh="1">
    <form method="POST" action="/license/generate" class="license-action-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-primary btn-generate" id="btn-generate"<%= eligibility && !eligibility.canGenerate ? ' disabled aria-disabled="true"' : '' %>>
        Generate Key
      </button>
    </form>
    <button type="button" class="btn btn-primary" data-download-keys>Download Key</button>
  </div>

  <%
    var licenseProviders = providers || [];
    var lootlabsReady = licenseProviders.some(function(p){ return p.provider === 'lootlabs'; });
    var linkvertiseReady = licenseProviders.some(function(p){ return p.provider === 'linkvertise'; });
    var canStartAds = eligibility && eligibility.canGenerate && !existingUnusedKey;
  %>
  <% if (canStartAds && (lootlabsReady || linkvertiseReady)) { %>
  <div class="provider-grid license-provider-grid" data-license-provider-actions data-csrf="<%= csrfToken %>">
    <p class="section-desc">Or choose an ad provider directly. Each click starts a fresh ad session.</p>
    <% if (lootlabsReady) { %>
    <button type="button" class="btn btn-primary btn-block btn-provider" data-ads-provider="lootlabs">Continue with LootLabs</button>
    <% } %>
    <% if (linkvertiseReady) { %>
    <button type="button" class="btn btn-primary btn-block btn-provider" data-ads-provider="linkvertise">Continue with Linkvertise</button>
    <% } %>
  </div>
  <% } %>

  <div class="license-message" data-license-message hidden></div>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Recent Generated Keys</h2>
    </div>
  </div>

  <% if (history && history.length > 0) { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Key</th>
            <th>Provider</th>
            <th>Status</th>
            <th>Generated</th>
            <th>Expires</th>
          </tr>
        </thead>
        <tbody>
          <% history.forEach(row => { %>
          <tr>
            <td class="key-cell"><code><%= fullKeyRow(row) %></code></td>
            <td><span class="badge badge-provider"><%= providerLabel(row.provider) %></span></td>
            <td><span class="badge <%= friendlyStatus(row) === 'Unredeemed' ? 'badge-green' : (friendlyStatus(row) === 'Expired' || friendlyStatus(row) === 'Revoked' ? 'badge-red' : 'badge-gray') %>"><%= friendlyStatus(row) %></span></td>
            <td class="muted-cell"><%= formatWibTimestamp(row.created_at) %></td>
            <td class="muted-cell"><%= formatWibTimestamp(row.expires_at || row.key_expires_at) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p class="empty-text">Each key works on one device and expires 48 hours after it is generated.</p>
  <% } else { %>
    <div class="empty-state">
      <p class="empty-title">No keys generated yet.</p>
    </div>
  <% } %>
</section>
