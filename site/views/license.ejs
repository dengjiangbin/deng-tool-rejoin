<% locals.activePage = 'license' %>

<div class="page-header">
  <div>
    <p class="eyebrow">License Center</p>
    <h1 class="page-title">My License</h1>
    <p class="page-subtitle">Complete one ad step, then redeem the key inside DENG Tool: Rejoin.</p>
  </div>
</div>

<section class="section-card generate-card" data-portal-step="license">
  <div class="generate-header">
    <div>
      <h2 class="section-title">Generate DENG Tool: Rejoin Key</h2>
      <p class="section-desc">Complete one ad step, then redeem the key inside DENG Tool: Rejoin.</p>
    </div>
  </div>

  <% if (flash && flash.cooldown && flash.cooldown > 0) { %>
    <div class="cooldown-notice" data-seconds="<%= flash.cooldown %>">
      Cooldown active: <span class="countdown"></span>
    </div>
  <% } else if (!existingUnusedKey && cooldown && !cooldown.allowed && cooldown.secondsLeft > 0) { %>
    <div class="cooldown-notice" data-seconds="<%= cooldown.secondsLeft %>">
      Cooldown active: <span class="countdown"></span>
    </div>
  <% } %>

  <% if (existingUnusedKey) { %>
    <div class="unused-key-recovery">
      <p class="empty-title">You already have an unused key.</p>
      <p class="empty-text">Copy or redeem this key before generating another one.</p>
      <div class="key-display-wrap">
        <code class="key-display" id="existing-key-value"><%= existingUnusedKey.key %></code>
        <button class="btn-copy" type="button" data-key="<%= existingUnusedKey.key %>" onclick="copyExistingKey(this)" aria-label="Copy key">Copy</button>
      </div>
      <% if (existingUnusedKey.expires_at_formatted && existingUnusedKey.expires_at_formatted !== 'None') { %>
        <p class="empty-text">Expires: <%= existingUnusedKey.expires_at_formatted %></p>
      <% } %>
    </div>
  <% } %>

  <div class="license-actions" data-license-actions data-csrf="<%= csrfToken %>">
    <form method="POST" action="/api/key/start" class="license-action-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-primary btn-generate" id="btn-generate">
        Generate Key
      </button>
    </form>
    <button type="button" class="btn btn-primary" data-open-license-modal="reset">Reset HWID</button>
    <button type="button" class="btn btn-primary" data-open-license-modal="redeem">Redeem Key</button>
    <button type="button" class="btn btn-primary" data-download-keys>Download Key</button>
  </div>

  <div class="license-message" data-license-message hidden></div>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Recent Generated Keys</h2>
    </div>
  </div>

  <% if (history && history.length > 0) { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Key</th>
            <th>Provider</th>
            <th>Status</th>
            <th>Generated</th>
          </tr>
        </thead>
        <tbody>
          <% history.forEach(row => { %>
          <tr>
            <td class="key-cell"><code><%= fullKeyRow(row) %></code></td>
            <td><span class="badge badge-provider"><%= providerLabel(row.provider) %></span></td>
            <td><span class="badge <%= friendlyStatus(row) === 'Generated' ? 'badge-green' : (friendlyStatus(row) === 'Expired' ? 'badge-red' : 'badge-gray') %>"><%= friendlyStatus(row) %></span></td>
            <td class="muted-cell"><%= formatWibTimestamp(row.created_at) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">
      <p class="empty-title">No keys generated yet.</p>
    </div>
  <% } %>
</section>

<div class="modal-backdrop" data-license-modal="reset" hidden>
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="reset-hwid-title">
    <div class="modal-header">
      <div>
        <h2 class="section-title" id="reset-hwid-title">Reset HWID</h2>
        <p class="section-desc">Move A Key To A New Device.</p>
      </div>
      <button type="button" class="modal-close" data-close-license-modal aria-label="Close">X</button>
    </div>
    <div class="license-modal-body">
      <div class="license-key-list" data-reset-key-list>
        <p class="empty-text">Loading keys...</p>
      </div>
      <div class="license-message" data-reset-message hidden></div>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-outline" data-close-license-modal>Cancel</button>
      <button type="button" class="btn btn-primary" data-confirm-reset>Confirm Reset</button>
    </div>
  </div>
</div>

<script>
function copyExistingKey(btn) {
  var key = btn.dataset.key;
  navigator.clipboard.writeText(key).then(function() {
    btn.textContent = 'Copied';
    btn.classList.add('copied');
    setTimeout(function() {
      btn.textContent = 'Copy';
      btn.classList.remove('copied');
    }, 2200);
  }).catch(function() {
    btn.textContent = 'Copy manually';
  });
}
</script>

<div class="modal-backdrop" data-license-modal="redeem" hidden>
  <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="redeem-key-title">
    <div class="modal-header">
      <div>
        <h2 class="section-title" id="redeem-key-title">Redeem Key</h2>
        <p class="section-desc">Claim An Existing DENG Tool: Rejoin Key.</p>
      </div>
      <button type="button" class="modal-close" data-close-license-modal aria-label="Close">X</button>
    </div>
    <div class="license-modal-body">
      <label class="form-label" for="redeem-license-key">Enter License Key</label>
      <input id="redeem-license-key" class="form-input" type="text" autocomplete="off" placeholder="DENG-XXXX-XXXX-XXXX-XXXX" data-redeem-key-input>
      <div class="license-message" data-redeem-message hidden></div>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-outline" data-close-license-modal>Cancel</button>
      <button type="button" class="btn btn-primary" data-confirm-redeem>Redeem Key</button>
    </div>
  </div>
</div>
