<% locals.activePage = 'license' %>

<div class="page-header">
  <div>
    <p class="eyebrow">License Center</p>
    <h1 class="page-title">My License</h1>
    <p class="page-subtitle">Generate a key through an ad unlock, then redeem it inside DENG Tool: Rejoin.</p>
  </div>
</div>

<section class="section-card status-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">Current License Status</h2>
      <p class="section-desc">Freshly generated keys are shown here as masked history after the result page.</p>
    </div>
    <span class="badge <%= stats.unredeemed > 0 ? 'badge-green' : 'badge-gray' %>">
      <%= stats.unredeemed > 0 ? 'Unredeemed key available' : 'No active generated key' %>
    </span>
  </div>
  <div class="mini-grid">
    <div>
      <span class="mini-label">Unredeemed</span>
      <strong><%= stats.unredeemed %></strong>
    </div>
    <div>
      <span class="mini-label">Expired</span>
      <strong><%= stats.expired %></strong>
    </div>
  </div>
</section>

<section class="section-card generate-card" data-portal-step="license">
  <div class="generate-header">
    <div>
      <h2 class="section-title">Generate Key</h2>
      <p class="section-desc">Complete LootLabs or Linkvertise. The final key is never placed in the URL.</p>
    </div>
  </div>

  <% if (flash && flash.cooldown) { %>
    <div class="cooldown-notice" data-seconds="<%= flash.cooldown %>">
      Cooldown active: <span class="countdown"></span>
    </div>
  <% } else if (cooldown && !cooldown.allowed) { %>
    <div class="cooldown-notice" data-seconds="<%= cooldown.secondsLeft %>">
      Cooldown active: <span class="countdown"></span>
    </div>
  <% } %>

  <form method="POST" action="/api/key/start">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="btn btn-primary btn-generate" id="btn-generate">
      Generate Key
    </button>
  </form>
</section>

<section class="section-card">
  <div class="section-header">
    <div>
      <h2 class="section-title">My Generated Keys</h2>
      <p class="section-desc">Older keys are masked. The fresh key appears only on the authorized result page.</p>
    </div>
  </div>

  <% if (history && history.length > 0) { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Key</th>
            <th>Provider</th>
            <th>Status</th>
            <th>Generated</th>
            <th>Unredeemed Expiry</th>
          </tr>
        </thead>
        <tbody>
          <% history.forEach(row => { %>
          <tr>
            <td class="key-cell"><code><%= maskKeyRow(row) %></code></td>
            <td><span class="badge badge-provider"><%= row.provider || 'Pending' %></span></td>
            <td><span class="badge <%= friendlyStatus(row) === 'Unredeemed' ? 'badge-green' : (friendlyStatus(row) === 'Expired' ? 'badge-red' : 'badge-gray') %>"><%= friendlyStatus(row) %></span></td>
            <td class="muted-cell"><%= new Date(row.created_at).toLocaleString() %></td>
            <td class="muted-cell"><%= row.key_expires_at ? new Date(row.key_expires_at).toLocaleString() : '-' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">
      <p class="empty-title">No generated keys</p>
      <p class="empty-text">Use Generate Key to start the ad unlock flow.</p>
    </div>
  <% } %>
</section>
