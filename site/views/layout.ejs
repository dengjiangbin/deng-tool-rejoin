<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'DENG Tool' %></title>
  <link rel="icon" type="image/png" href="/public/img/deng-logo.png?v=<%= assetVersion %>">
  <link rel="stylesheet" href="/public/css/style.css?v=<%= assetVersion %>">
</head>
<body class="<%= user ? 'app-layout' : 'auth-layout' %>">

<% if (user) { %>
  <nav class="sidebar" aria-label="Main navigation">
    <div class="sidebar-brand">
      <span class="brand-mark logo-mark" aria-hidden="true">
        <img src="/public/img/deng-logo.png?v=<%= assetVersion %>" alt="">
      </span>
      <span class="brand-name">DENG <span class="brand-accent">Tool</span></span>
    </div>

    <ul class="nav-list">
      <li>
        <a href="/dashboard" class="nav-link <%= locals.activePage === 'dashboard' ? 'active' : '' %>">
          <span class="nav-icon" aria-hidden="true">D</span>
          <span>Dashboard</span>
        </a>
      </li>
      <li>
        <a href="/license" class="nav-link <%= locals.activePage === 'license' ? 'active' : '' %>">
          <span class="nav-icon" aria-hidden="true">K</span>
          <span>My License</span>
        </a>
      </li>
    </ul>

    <div class="sidebar-bottom">
      <div class="user-pill">
        <% if (user.discord_avatar && user.discord_user_id) { %>
          <img src="https://cdn.discordapp.com/avatars/<%= user.discord_user_id %>/<%= user.discord_avatar %>.webp?size=64"
               alt="" class="user-avatar" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="user-avatar-placeholder" style="display:none"><%= (user.username||'?')[0].toUpperCase() %></div>
        <% } else { %>
          <div class="user-avatar-placeholder"><%= (user.username||'?')[0].toUpperCase() %></div>
        <% } %>
        <span class="user-name text-truncate"><%= user.username %></span>
      </div>
      <form method="POST" action="/auth/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="nav-link logout-link">
          <span class="nav-icon" aria-hidden="true">X</span>
          <span>Logout</span>
        </button>
      </form>
    </div>
  </nav>

  <main class="main-content">
    <% if (flash && flash.error) { %>
      <div class="alert alert-error" role="alert"><%= flash.error %></div>
    <% } %>
    <% if (flash && flash.success) { %>
      <div class="alert alert-success" role="alert"><%= flash.success %></div>
    <% } %>
    <%- body %>
  </main>
<% } else { %>
  <%- body %>
<% } %>

<script src="/public/js/app.js" defer></script>
<%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
