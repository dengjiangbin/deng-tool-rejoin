<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'DENG Tool' %></title>
  <link rel="icon" type="image/svg+xml" href="/public/favicon.svg">
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body class="<%= user ? 'app-layout' : 'auth-layout' %>">

<% if (user) { %>
  <!-- Sidebar navigation (only for authenticated pages) -->
  <nav class="sidebar">
    <div class="sidebar-brand">
      <span class="brand-icon">⚙️</span>
      <span class="brand-name">DENG<span class="brand-accent">Tool</span></span>
    </div>

    <ul class="nav-list">
      <li>
        <a href="/dashboard" class="nav-link <%= locals.activePage === 'dashboard' ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7A1 1 0 003 11h1v6a1 1 0 001 1h4v-5h2v5h4a1 1 0 001-1v-6h1a1 1 0 00.707-1.707l-7-7z"/></svg>
          Dashboard
        </a>
      </li>
      <li>
        <a href="/license" class="nav-link <%= locals.activePage === 'license' ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M18 8a6 6 0 01-7.743 5.743L10 14l-1 1-1 1H6v2H2v-4l4.257-4.257A6 6 0 1118 8zm-6-4a1 1 0 100 2 2 2 0 012 2 1 1 0 102 0 4 4 0 00-4-4z" clip-rule="evenodd"/></svg>
          My License
        </a>
      </li>
    </ul>

    <div class="sidebar-bottom">
      <div class="user-pill">
        <% if (user.discord_avatar && user.discord_user_id) { %>
          <img src="https://cdn.discordapp.com/avatars/<%= user.discord_user_id %>/<%= user.discord_avatar %>.webp?size=64"
               alt="avatar" class="user-avatar" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="user-avatar-placeholder" style="display:none"><%= (user.username||'?')[0].toUpperCase() %></div>
        <% } else { %>
          <div class="user-avatar-placeholder"><%= (user.username||'?')[0].toUpperCase() %></div>
        <% } %>
        <span class="user-name text-truncate"><%= user.username %></span>
      </div>
      <form method="POST" action="/auth/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn-logout">Sign Out</button>
      </form>
    </div>
  </nav>

  <!-- Main content -->
  <main class="main-content">
    <% if (flash && flash.error) { %>
      <div class="alert alert-error" role="alert"><%= flash.error %></div>
    <% } %>
    <% if (flash && flash.success) { %>
      <div class="alert alert-success" role="alert"><%= flash.success %></div>
    <% } %>

    <%- body %>
  </main>

<% } else { %>
  <!-- Auth layout (login page) -->
  <%- body %>
<% } %>

<script src="/public/js/app.js" defer></script>
</body>
</html>
