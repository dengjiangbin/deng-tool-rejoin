<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'DENG Tool' %></title>
  <script>
    (function() {
      try {
        var saved = localStorage.getItem('deng_tool_theme');
        var theme = saved === 'light' || saved === 'dark'
          ? saved
          : (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme;
      } catch (_) {
        document.documentElement.dataset.theme = 'dark';
      }
    }());
  </script>
  <link rel="icon" type="image/png" href="/public/img/deng-logo.png?v=<%= assetVersion %>">
  <link rel="stylesheet" href="/public/css/style.css?v=<%= assetVersion %>">
</head>
<body class="<%= user ? 'app-layout' : 'auth-layout' %>">

<% if (user) { %>
  <nav class="sidebar" aria-label="Main navigation">
    <div class="sidebar-brand">
      <span class="brand-mark logo-mark" aria-hidden="true">
        <img src="/public/img/deng-logo.png?v=<%= assetVersion %>" alt="">
      </span>
      <span class="brand-name gradient-brand-text">DENG Tool</span>
    </div>

    <ul class="nav-list">
      <li>
        <a href="/dashboard" class="nav-link <%= locals.activePage === 'dashboard' ? 'active' : '' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <rect x="3" y="3" width="7" height="8" rx="2"></rect>
              <rect x="14" y="3" width="7" height="5" rx="2"></rect>
              <rect x="14" y="12" width="7" height="9" rx="2"></rect>
              <rect x="3" y="15" width="7" height="6" rx="2"></rect>
            </svg>
          </span>
          <span>Dashboard</span>
        </a>
      </li>
      <li>
        <a href="/license" class="nav-link <%= locals.activePage === 'license' ? 'active' : '' %>">
          <span class="nav-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <circle cx="7.5" cy="14.5" r="3.5"></circle>
              <path d="M10.8 12.2 21 2"></path>
              <path d="m16 7 2 2"></path>
              <path d="m13.5 9.5 2 2"></path>
            </svg>
          </span>
          <span>My License</span>
        </a>
      </li>
    </ul>

    <div class="sidebar-bottom">
      <div class="user-pill">
        <% if (user.discord_avatar && user.discord_user_id) { %>
          <img src="https://cdn.discordapp.com/avatars/<%= user.discord_user_id %>/<%= user.discord_avatar %>.webp?size=64"
               alt="" class="user-avatar" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="user-avatar-placeholder" style="display:none"><%= (user.username||'?')[0].toUpperCase() %></div>
        <% } else { %>
          <div class="user-avatar-placeholder"><%= (user.username||'?')[0].toUpperCase() %></div>
        <% } %>
        <span class="user-name text-truncate"><%= user.username %></span>
      </div>
      <div class="sidebar-actions">
        <button type="button" class="theme-toggle" data-theme-toggle aria-label="Switch theme" title="Switch theme">
          <span class="theme-toggle-track" aria-hidden="true">
            <span class="theme-toggle-knob">
              <span class="theme-toggle-icon theme-icon-sun">
                <svg viewBox="0 0 24 24" focusable="false">
                  <circle cx="12" cy="12" r="4"></circle>
                  <path d="M12 2v2"></path>
                  <path d="M12 20v2"></path>
                  <path d="m4.93 4.93 1.41 1.41"></path>
                  <path d="m17.66 17.66 1.41 1.41"></path>
                  <path d="M2 12h2"></path>
                  <path d="M20 12h2"></path>
                  <path d="m6.34 17.66-1.41 1.41"></path>
                  <path d="m19.07 4.93-1.41 1.41"></path>
                </svg>
              </span>
              <span class="theme-toggle-icon theme-icon-moon">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M20.5 14.5A8.5 8.5 0 0 1 9.5 3.5 7 7 0 1 0 20.5 14.5Z"></path>
                </svg>
              </span>
            </span>
          </span>
          <span class="theme-toggle-label" data-theme-label>Dark</span>
        </button>
        <form method="POST" action="/auth/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="nav-link logout-link">
            <span class="nav-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <path d="M16 17l5-5-5-5"></path>
                <path d="M21 12H9"></path>
              </svg>
            </span>
            <span>Logout</span>
          </button>
        </form>
      </div>
    </div>
  </nav>

  <main class="main-content">
    <% if (flash && flash.error) { %>
      <div class="alert alert-error" role="alert"><%= flash.error %></div>
    <% } %>
    <% if (flash && flash.success) { %>
      <div class="alert alert-success" role="alert"><%= flash.success %></div>
    <% } %>
    <%- body %>
  </main>
<% } else { %>
  <%- body %>
<% } %>

<script src="/public/js/app.js?v=<%= assetVersion %>" defer></script>
<%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
