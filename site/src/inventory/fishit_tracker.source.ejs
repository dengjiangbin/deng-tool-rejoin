    }
    .dashboard-period-custom__panel {
      display:none;
      align-items:center;
      gap:8px;
      flex-wrap:wrap;
      padding:10px 12px;
      border:1px solid var(--border);
      border-radius:var(--radius-lg);
      background:var(--surface2);
    }
