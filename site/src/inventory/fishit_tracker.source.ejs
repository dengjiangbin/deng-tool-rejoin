  <style>
    /* BLOCKER10ZTA_INVENTORY_DESKTOP_SIDEBAR_2026_06_11 */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0f14;
      --surface:   #161a22;
