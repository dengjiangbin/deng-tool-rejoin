      right:0;
      width:14px;
      height:14px;
      margin:6px;
      border:2px solid rgba(96,165,250,.25);
      border-top-color:rgba(96,165,250,.85);
      border-radius:50%;
      animation:dashboardToolbarSpin .65s linear infinite;
      pointer-events:none;
