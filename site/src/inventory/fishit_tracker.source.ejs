  let dashboardPeriod = 'all';
  let dashboardCustomFrom = '';
  let dashboardCustomTo = '';
  const dashboardMemCache = new Map();
  const DASHBOARD_MEM_TTL_MS = 10_000;
  const DASHBOARD_SWR_STALE_MS = 10_000;
